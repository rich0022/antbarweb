---
import SiteShellLayout from './SiteShellLayout.astro';
import { ANIMATION_INLINE_CSS, MEGA_MENU_STYLE_CSS, SITE_OVERFLOW_GUARD_CSS } from '../data/site-assets';
import '../styles/home-bundle.css';
import '../styles/home-hero.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'ANTBAR', description = '' } = Astro.props;
const bodyClass =
  'home wp-singular page-template-default page page-id-2 wp-custom-logo wp-embed-responsive wp-theme-hello-elementor hello-elementor-default elementor-default elementor-kit-305 elementor-page elementor-page-2';
---

<SiteShellLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  inlineStyles={[ANIMATION_INLINE_CSS, SITE_OVERFLOW_GUARD_CSS, MEGA_MENU_STYLE_CSS]}
>
  <slot />
</SiteShellLayout>
