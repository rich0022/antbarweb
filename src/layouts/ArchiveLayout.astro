---
import SiteShellLayout from './SiteShellLayout.astro';
import { ANIMATION_INLINE_CSS } from '../data/site-assets';
import '../styles/archive-list.css';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  canonical?: string;
  image?: string;
}

const {
  title = 'ANTBAR',
  description = '',
  bodyClass = 'archive-page-body',
  canonical,
  image,
} = Astro.props;
---

<SiteShellLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  canonical={canonical}
  image={image}
  inlineStyles={[ANIMATION_INLINE_CSS]}
>
  <slot />
</SiteShellLayout>
