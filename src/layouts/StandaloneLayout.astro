---
import LegacyShellLayout from './LegacyShellLayout.astro';
import { ANIMATION_INLINE_CSS } from '../data/site-assets';

interface Props {
  title?: string;
  description?: string;
  pageId?: string;
  extraStylesheets?: string[];
}

const { title = 'ANTBAR', description = '', pageId, extraStylesheets } = Astro.props;
const pageClass = pageId ? ` elementor-page elementor-page-${pageId}` : '';
const bodyClass = `wp-singular wp-custom-logo wp-embed-responsive wp-theme-hello-elementor hello-elementor-default elementor-default elementor-kit-305${pageClass}`;
---

<LegacyShellLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  stylesheets={extraStylesheets}
  inlineStyles={[ANIMATION_INLINE_CSS]}
>
  <slot />
</LegacyShellLayout>
