---
import SiteFooter from '../components/site/SiteFooter.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import { getPopupTemplates, mergeMirrorHeadAssets } from '../lib/mirror-assets';
import { ANIMATION_INLINE_CSS, ELEMENTOR_LAZY_CSS } from '../data/site-assets';
import '../styles/home-bundle.css';

interface Props {
  title?: string;
  description?: string;
  mirrorRoute?: string;
  /** Use bundled CSS (still loads JS from mirror for guaranteed functionality) */
  standalone?: boolean;
}

const { title = 'ANTBAR', description = '', mirrorRoute = '', standalone = false } = Astro.props;
const assets = await mergeMirrorHeadAssets(mirrorRoute);
const popupTemplates = standalone ? await getPopupTemplates() : '';
const stylesheets = standalone ? [] : assets.stylesheets;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {assets.inlineStyles.map((css) => <style set:html={css} />)}
    {stylesheets.map((href) => <link rel="stylesheet" href={href} />)}
    {assets.headScripts.map((script) =>
      script.src ? <script src={script.src} is:inline></script>
      : script.inline ? <script set:html={script.inline} is:inline></script>
      : null,
    )}
    <style set:html={ANIMATION_INLINE_CSS} />
    <style set:html={ELEMENTOR_LAZY_CSS} />
  </head>
  <body class={assets.bodyClass}>
    <script is:inline>
      document.addEventListener('click', (event) => {
        const anchor = event.target.closest('a[href]');
        if (!anchor) return;
        const href = anchor.getAttribute('href');
        if (!href || !/^https?:\/\/(?:www\.)?antbar\.com/i.test(href)) return;
        event.preventDefault();
        const localPath = href.replace(/^https?:\/\/(?:www\.)?antbar\.com/i, '') || '/';
        window.location.assign(localPath);
      }, true);
    </script>
    <SiteHeader />
    <slot />
    <SiteFooter />
    {assets.footerScripts.map((script) =>
      script.src ? <script src={script.src} is:inline></script>
      : script.inline ? <script set:html={script.inline} is:inline></script>
      : null,
    )}
    {standalone && <Fragment set:html={popupTemplates} />}
  </body>
</html>
