---
import SiteShellLayout from './SiteShellLayout.astro';
import { ANIMATION_INLINE_CSS } from '../data/site-assets';
import '../styles/contact.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'ANTBAR', description = '' } = Astro.props;
const bodyClass = 'contact-page-body';
---

<SiteShellLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  inlineStyles={[ANIMATION_INLINE_CSS]}
>
  <slot />
</SiteShellLayout>
