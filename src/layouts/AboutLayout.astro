---
import SiteShellLayout from './SiteShellLayout.astro';
import { ANIMATION_INLINE_CSS } from '../data/site-assets';
import '../styles/about-us.css';

import type { BreadcrumbItem } from '../components/seo/JsonLd.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title = 'ANTBAR', description = '', canonical, image, breadcrumbs } = Astro.props;
const bodyClass = 'about-page-body';
---

<SiteShellLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  canonical={canonical}
  image={image}
  breadcrumbs={breadcrumbs}
  inlineStyles={[ANIMATION_INLINE_CSS]}
>
  <slot />
</SiteShellLayout>
