---
import SiteShellLayout from './SiteShellLayout.astro';
import { ANIMATION_INLINE_CSS } from '../data/site-assets';
import '../styles/about-us.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'ANTBAR', description = '' } = Astro.props;
const bodyClass = 'wp-singular page-template-default wp-custom-logo wp-embed-responsive wp-theme-hello-elementor hello-elementor-default elementor-default elementor-kit-305 about-page-body';
---

<SiteShellLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  inlineStyles={[ANIMATION_INLINE_CSS]}
>
  <slot />
</SiteShellLayout>
