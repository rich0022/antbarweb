---
import LegacyShellLayout from './LegacyShellLayout.astro';
import { ANIMATION_INLINE_CSS, ELEMENTOR_LAZY_CSS } from '../data/site-assets';
import { getMirrorHeadAssets } from '../lib/mirror-assets';

interface Props {
  title: string;
  description?: string;
  mirrorRoute?: string;
  extraStylesheets?: string[];
  bodyClass?: string;
}

const {
  title,
  description = '',
  mirrorRoute = '',
  extraStylesheets = [],
  bodyClass: bodyClassOverride = '',
} = Astro.props;

const assets = mirrorRoute ? await getMirrorHeadAssets(mirrorRoute) : null;
const bodyClass =
  bodyClassOverride ||
  assets?.bodyClass ||
  'wp-singular wp-custom-logo wp-embed-responsive wp-theme-hello-elementor hello-elementor-default elementor-default elementor-kit-305';
const stylesheets = [...new Set(['/assets/article-shell-bundle.css', ...extraStylesheets])];
---

<LegacyShellLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  stylesheets={stylesheets}
  inlineStyles={[...(assets?.inlineStyles ?? []), ANIMATION_INLINE_CSS, ELEMENTOR_LAZY_CSS]}
>
  <slot />
</LegacyShellLayout>
