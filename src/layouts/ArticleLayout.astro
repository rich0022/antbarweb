---
import SiteShellLayout from './SiteShellLayout.astro';
import { ANIMATION_INLINE_CSS } from '../data/site-assets';
import '../styles/article-page.css';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const {
  title,
  description = '',
  bodyClass = 'article-page-body',
} = Astro.props;
---

<SiteShellLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  inlineStyles={[ANIMATION_INLINE_CSS]}
>
  <slot />
</SiteShellLayout>
