---
import SiteShellLayout from './SiteShellLayout.astro';
import '../styles/site-shell-legacy.css';
import type { MirrorScript } from '../lib/mirror-assets';
import type { BreadcrumbItem, ProductData, ArticleData, FaqData } from '../components/seo/JsonLd.astro';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  stylesheets?: string[];
  inlineStyles?: string[];
  headScripts?: MirrorScript[];
  footerScripts?: MirrorScript[];
  canonical?: string;
  image?: string;
  ogType?: 'website' | 'article' | 'product';
  article?: { publishedAt?: string; updatedAt?: string; author?: string; tags?: string[] };
  breadcrumbs?: BreadcrumbItem[];
  jsonProduct?: ProductData;
  jsonArticle?: ArticleData;
  jsonFaq?: FaqData;
}

const {
  title = 'ANTBAR',
  description = '',
  bodyClass = '',
  stylesheets = [],
  inlineStyles = [],
  headScripts = [],
  footerScripts = [],
  canonical,
  image,
  ogType,
  article,
  breadcrumbs,
  jsonProduct,
  jsonArticle,
  jsonFaq,
} = Astro.props;
---

<SiteShellLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  stylesheets={stylesheets}
  inlineStyles={inlineStyles}
  headScripts={headScripts}
  footerScripts={footerScripts}
  canonical={canonical}
  image={image}
  ogType={ogType}
  article={article}
  breadcrumbs={breadcrumbs}
  jsonProduct={jsonProduct}
  jsonArticle={jsonArticle}
  jsonFaq={jsonFaq}
>
  <slot />
</SiteShellLayout>
