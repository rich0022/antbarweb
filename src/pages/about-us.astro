---
import { getCollection } from 'astro:content';
import AboutLayout from '../layouts/AboutLayout.astro';
import { ABOUT_HERO, ABOUT_SECTIONS } from '../data/about-us';

const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === 'about-us');
const brandStory = ABOUT_SECTIONS[0]!;
const detailSections = ABOUT_SECTIONS.slice(1);
---

<AboutLayout
  title={entry?.data.title ?? 'About Antbar | The Best disposable vape Wholesale'}
  description={entry?.data.description ?? ''}
>
  <main id="content" class="site-main about-page">
    <section class="about-hero scroll-bn" aria-label="About Antbar hero">
      <picture class="about-hero__picture">
        <source
          media="(max-width: 767px)"
          srcset={ABOUT_HERO.mobileImage.srcset}
          sizes={ABOUT_HERO.mobileImage.sizes}
        />
        <img
          loading="eager"
          decoding="async"
          width={ABOUT_HERO.desktopImage.width}
          height={ABOUT_HERO.desktopImage.height}
          src={ABOUT_HERO.desktopImage.src}
          srcset={ABOUT_HERO.desktopImage.srcset}
          sizes={ABOUT_HERO.desktopImage.sizes}
          alt=""
        />
      </picture>
      <div class="about-hero__overlay">
        <div class="about-hero__copy elementor-invisible" data-settings='{"animation":"fadeInUp"}'>
          <p>{ABOUT_HERO.headings[0]}</p>
          <p><strong>{ABOUT_HERO.headings[1]}</strong></p>
        </div>
      </div>
    </section>

    <section class="about-feature about-feature--brand" aria-labelledby="about-brand-title">
      <div class="about-feature__inner">
        <div class="about-feature__media elementor-invisible" data-settings='{"_animation":"fadeInRight"}'>
          <a class="about-feature__image-link" href={brandStory.buttonHref} aria-label={brandStory.heading}>
            <img
              loading="lazy"
              decoding="async"
              width={brandStory.image.width}
              height={brandStory.image.height}
              src={brandStory.image.src}
              alt=""
              srcset={brandStory.image.srcset}
              sizes={brandStory.image.sizes}
            />
          </a>
        </div>
        <div class="about-feature__copy elementor-invisible" data-settings='{"_animation":"fadeInLeft"}'>
          <h1 id="about-brand-title">{brandStory.heading}</h1>
          <p>{brandStory.text}</p>
          <a class="about-feature__button" href={brandStory.buttonHref}>View More</a>
        </div>
      </div>
    </section>

    <section class="about-sections" id="about-sections" aria-label="About Antbar sections">
      {detailSections.map((section) => (
        <article class="about-section">
          <div class="about-section__inner">
            <div class="about-section__media elementor-invisible" data-settings='{"_animation":"fadeInLeft"}'>
              <a class="about-section__image-link" href={section.buttonHref} aria-label={section.heading.replace('\n', ' ')}>
                <img
                  loading="lazy"
                  decoding="async"
                  width={section.image.width}
                  height={section.image.height}
                  src={section.image.src}
                  alt=""
                  srcset={section.image.srcset}
                  sizes={section.image.sizes}
                />
              </a>
            </div>
            <div class="about-section__copy elementor-invisible" data-settings='{"_animation":"fadeInRight"}'>
              <h2 set:html={section.heading.replace('\n', '<br />')} />
              <p>{section.text}</p>
              <a class="about-section__button" href={section.buttonHref}>View More</a>
            </div>
          </div>
        </article>
      ))}
    </section>

    <div class="about-page__spacer" aria-hidden="true"></div>
  </main>
</AboutLayout>
