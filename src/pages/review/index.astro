---
import { getCollection } from 'astro:content';
import ArchiveFeaturedPost from '../../components/archive/ArchiveFeaturedPost.astro';
import ArchivePageHero from '../../components/archive/ArchivePageHero.astro';
import PostsWidget from '../../components/archive/PostsWidget.astro';
import StandaloneLayout from '../../layouts/StandaloneLayout.astro';
import { REVIEW_ARCHIVE_PAGE } from '../../data/archive-pages';
import {
  buildArchivePostsWidget,
  listArchivePosts,
  resolveFeaturedArchivePost,
} from '../../lib/archive-posts';
import '../../styles/review-bundle.css';

const allReviews = await getCollection('review');
const indexEntry = allReviews.find((entry) => entry.id === 'index' || entry.data.slug === 'review');
const pageConfig = REVIEW_ARCHIVE_PAGE;

const allCards = await listArchivePosts('review', allReviews);
const featured = await resolveFeaturedArchivePost('review', pageConfig.featuredSlug, allReviews);
const gridCards = allCards.filter((card) => !card.href.endsWith(`/${pageConfig.featuredSlug}/`));
const postsWidget = buildArchivePostsWidget('review', gridCards);
---

<StandaloneLayout
  title={indexEntry?.data.title ?? 'ANTBAR Reviews'}
  description={indexEntry?.data.description ?? ''}
  pageId={pageConfig.pageId}
>
  <main id="content" class={`site-main post-${pageConfig.pageId} page type-page status-publish hentry`}>
    <div class="page-content">
      <div
        data-elementor-type="wp-page"
        data-elementor-id={pageConfig.pageId}
        class={`elementor elementor-${pageConfig.pageId}`}
        data-elementor-post-type="page"
      >
        <ArchivePageHero variant="review" {...pageConfig.hero} />
        {featured && <ArchiveFeaturedPost {...featured} />}
        <div
          class="elementor-element elementor-element-beacd23 e-flex e-con-boxed e-con e-parent"
          data-id="beacd23"
          data-element_type="container"
          data-settings='{"background_background":"classic"}'
        >
          <div class="e-con-inner">
            <PostsWidget widget={postsWidget} />
          </div>
        </div>
      </div>
    </div>
  </main>
</StandaloneLayout>
