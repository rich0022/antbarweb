---
import { getCollection, getEntry, render } from 'astro:content';
import ArticlePage from '../../components/article/ArticlePage.astro';
import ArticleShellRuntime from '../../components/article/ArticleShellRuntime.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { contentEntrySlug } from '../../lib/content-entry';
import { resolveReviewUrlSlug, REVIEW_URL_ALIASES } from '../../lib/route-aliases';
import {
  REVIEW_FEATURED_ITEMS,
  REVIEW_HOT_SALE_PRODUCTS,
  REVIEW_LATEST_ITEMS,
  REVIEW_RELATED_ITEMS,
  extractTocItems,
  readMarkdownBody,
  readMirrorArticleMeta,
  readMirrorPublishedLabel,
} from '../../lib/article-page';

export async function getStaticPaths() {
  const contentPosts = await getCollection('review');
  const paths = new Map<string, Record<string, unknown>>();

  for (const entry of contentPosts) {
    if (entry.id === 'index' || entry.id === 'review' || entry.data.slug === 'review') continue;
    paths.set(contentEntrySlug(entry.id, 'review'), { entryId: entry.id });
  }

  for (const [alias, target] of Object.entries(REVIEW_URL_ALIASES)) {
    const targetProps = paths.get(target);
    if (targetProps) paths.set(alias, targetProps);
  }

  return [...paths.entries()].map(([slug, props]) => ({
    params: { slug },
    props: { slug, ...props },
  }));
}

const props = Astro.props as {
  slug: string;
  entryId: string;
};

const canonicalSlug = resolveReviewUrlSlug(props.slug);
const entry = await getEntry('review', props.entryId);
if (!entry) {
  throw new Error(`Missing review entry for ${props.entryId}`);
}
const { Content } = await render(entry);
const [markdownBody, publishedLabel, articleMeta] = await Promise.all([
  readMarkdownBody('review', props.entryId),
  readMirrorPublishedLabel(`review/${canonicalSlug}`),
  readMirrorArticleMeta(`review/${canonicalSlug}`),
]);

const tocItems = extractTocItems(markdownBody);
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description ?? entry.data.excerpt ?? ''}
  mirrorRoute={`review/${canonicalSlug}`}
  bodyClass={articleMeta.bodyClass}
>
  <ArticlePage
    title={entry.data.title}
    sectionLabel="Review"
    currentPostId={articleMeta.postId}
    publishedLabel={publishedLabel}
    tocItems={tocItems}
    latestItems={REVIEW_LATEST_ITEMS}
    relatedTitle="Related Review"
    relatedItems={REVIEW_RELATED_ITEMS}
    featuredItems={REVIEW_FEATURED_ITEMS}
    hotProducts={REVIEW_HOT_SALE_PRODUCTS}
  >
    <Content />
  </ArticlePage>
  <ArticleShellRuntime
    postId={articleMeta.postId ?? 3650}
    title={entry.data.title}
    excerpt={entry.data.excerpt ?? entry.data.description ?? ''}
    featuredImage={entry.data.heroImage ?? entry.data.featuredImage ?? '/wp-content/uploads/2024/05/LOGO.png'}
  />
</ArticleLayout>
