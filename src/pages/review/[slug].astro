---
import { getCollection, getEntry, render } from 'astro:content';
import ArticlePage from '../../components/article/ArticlePage.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { contentEntrySlug } from '../../lib/content-entry';
import { REVIEW_URL_ALIASES } from '../../lib/route-aliases';
import {
  REVIEW_FEATURED_ITEMS,
  REVIEW_HOT_SALE_PRODUCTS,
  REVIEW_LATEST_ITEMS,
  REVIEW_RELATED_ITEMS,
  extractTocItems,
  formatPublishedLabel,
  readMarkdownBody,
} from '../../lib/article-page';

export async function getStaticPaths() {
  const contentPosts = await getCollection('review');
  const paths = new Map<string, { entryId: string }>();

  for (const entry of contentPosts) {
    if (entry.id === 'index' || entry.id === 'review' || entry.data.slug === 'review') continue;
    paths.set(contentEntrySlug(entry.id, 'review'), { entryId: entry.id });
  }

  for (const [alias, target] of Object.entries(REVIEW_URL_ALIASES)) {
    const targetProps = paths.get(target);
    if (targetProps) paths.set(alias, targetProps);
  }

  return [...paths.entries()].map(([slug, routeProps]) => ({
    params: { slug },
    props: { slug, ...routeProps },
  }));
}

const props = Astro.props as {
  slug: string;
  entryId: string;
};

const entry = await getEntry('review', props.entryId);
if (!entry) {
  throw new Error(`Missing review entry for ${props.entryId}`);
}

const title = entry.data.seo?.title ?? entry.data.title;
const description = entry.data.seo?.description ?? entry.data.description ?? entry.data.excerpt ?? '';
const canonicalOverride = entry.data.seo?.canonical;
const publishedLabel = formatPublishedLabel(entry.data.publishedAt);

const [{ Content }, markdownBody] = await Promise.all([
  render(entry),
  readMarkdownBody('review', props.entryId),
]);

const tocItems = extractTocItems(markdownBody);
---

<ArticleLayout
  title={title}
  description={description}
  bodyClass="article-page-body review-article-body"
  canonical={canonicalOverride ?? `/review/${props.slug}/`}
  image={entry.data.heroImage}
  article={{
    publishedAt: entry.data.publishedAt,
    updatedAt: entry.data.updatedAt,
    tags: entry.data.tags,
  }}
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'Reviews', item: '/review/' },
    { name: entry.data.title, item: `/review/${props.slug}/` },
  ]}
  jsonArticle={{
    headline: entry.data.title,
    description: description,
    image: entry.data.heroImage,
    datePublished: entry.data.publishedAt,
    dateModified: entry.data.updatedAt,
    publisher: 'ANTBAR',
  }}
>
  <ArticlePage
    title={title}
    sectionLabel="Review"
    publishedLabel={publishedLabel}
    tocItems={tocItems}
    latestItems={REVIEW_LATEST_ITEMS}
    relatedTitle="Related Review"
    relatedItems={REVIEW_RELATED_ITEMS}
    featuredItems={REVIEW_FEATURED_ITEMS}
    hotProducts={REVIEW_HOT_SALE_PRODUCTS}
  >
    <Content />
  </ArticlePage>
</ArticleLayout>
