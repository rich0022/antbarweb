<script is:inline>
  (() => {
    const cont = document.getElementById('haConts');
    if (!cont) return;
    const sections = cont.querySelectorAll('.ha-one');
    const nums = cont.querySelectorAll('.ha-num .elementor-heading-title');
    if (!sections.length || !nums.length) return;
    const tabs = document.createElement('div');
    tabs.className = 'ha-tabs';
    nums.forEach(n => { const t = n.cloneNode(true); t.classList.add('ha-tab'); tabs.appendChild(t); });
    cont.prepend(tabs);
    const tabEls = tabs.querySelectorAll('.ha-tab');
    let current = -1, scrolling = true;

    tabEls.forEach((tab, i) => {
      tab.addEventListener('click', () => {
        if (!scrolling) return;
        scrolling = false;
        tabEls.forEach((t, j) => t.classList.toggle('active', j === i));
        sections.forEach((s, j) => s.classList.toggle('active', j === i));
        sections[i].scrollIntoView({ behavior: 'smooth', block: 'start' });
        setTimeout(() => { scrolling = true; }, 400);
      });
    });

    window.addEventListener('scroll', () => {
      if (!scrolling) return;
      const mid = window.scrollY + window.innerHeight / 2;
      let best = -1, bestDist = Infinity;
      sections.forEach((s, i) => {
        const top = s.getBoundingClientRect().top + window.scrollY;
        const dist = Math.abs(top - mid);
        if (dist < bestDist && top < mid) { bestDist = dist; best = i; }
      });
      if (best >= 0 && best !== current) {
        current = best;
        tabEls.forEach((t, j) => t.classList.toggle('active', j === best));
        sections.forEach((s, j) => s.classList.toggle('active', j === best));
      }
    }, { passive: true });
    window.dispatchEvent(new Event('scroll'));

    const header = document.querySelector('header');
    function sticky() {
      if (!header) return;
      const ct = cont.getBoundingClientRect().top + window.scrollY;
      const hh = header.offsetHeight;
      if (window.scrollY + hh >= ct) { tabs.classList.add('fixed'); tabs.style.top = hh + 'px'; }
      else { tabs.classList.remove('fixed'); tabs.style.top = '0'; }
    }
    window.addEventListener('scroll', sticky, { passive: true });
    sticky();
  })();
</script>
