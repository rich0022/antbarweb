---
import { getCollection } from 'astro:content';
import SiteShellLayout from '../layouts/SiteShellLayout.astro';
import { ANIMATION_INLINE_CSS } from '../data/site-assets';
import '../styles/intelligent-manufacturing.css';

const pages = await getCollection('pages');
const entry = pages.find((page) => page.id === 'intelligent-manufacturing');
const bodyClass =
  'intelligent-manufacturing-body';

const highlights = [
  {
    num: '01',
    heading: 'Pioneer in<br />Automatic Robots',
    text: 'The automatic robotic arms are wholly invented and independently developed by our team. They are used to manufacture a diverse range of vaping products including disposable products and POD systems, etc.',
  },
  {
    num: '02',
    heading: 'Higher Effificiency<br />and Lower Cost',
    text: "Using intelligent manufacturing approach, Antbar's automated manufacturing process drastically decreases the labour cost and time and resource wastage compared to traditional manual assembly methods,and improves production efficiency by more than 50%.",
  },
  {
    num: '03',
    heading: 'Process Monitoring<br />and Quality Control',
    text: 'Automated production stringently monitor the problems that need to be addressed. By collecting and analyzing data, we enable to preview the condition of our production lines.',
  },
] as const;
---

<SiteShellLayout
  title={entry?.data.title ?? 'Intelligent Manufacturing'}
  description={entry?.data.description ?? ''}
  bodyClass={bodyClass}
  inlineStyles={[ANIMATION_INLINE_CSS]}
>
  <main id="content" class="site-main manufacturing-page">
    <section class="manufacturing-hero scroll-bn" aria-label="Intelligent Manufacturing hero">
      <picture class="manufacturing-hero__picture">
        <source
          media="(max-width: 767px)"
          srcset="/wp-content/uploads/2024/05/Intelligent-Manufacturing.jpg 1170w, /wp-content/uploads/2024/05/Intelligent-Manufacturing-182x300.jpg 182w, /wp-content/uploads/2024/05/Intelligent-Manufacturing-620x1024.jpg 620w, /wp-content/uploads/2024/05/Intelligent-Manufacturing-768x1268.jpg 768w, /wp-content/uploads/2024/05/Intelligent-Manufacturing-931x1536.jpg 931w"
          sizes="(max-width: 1170px) 100vw, 1170px"
        />
        <img
          loading="eager"
          decoding="async"
          width="2000"
          height="975"
          src="/wp-content/uploads/2024/04/Intelligent-Manufacturing-1.jpg"
          srcset="/wp-content/uploads/2024/04/Intelligent-Manufacturing-1.jpg 2000w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-1-300x146.jpg 300w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-1-1024x499.jpg 1024w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-1-768x374.jpg 768w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-1-1536x749.jpg 1536w"
          sizes="(max-width: 2000px) 100vw, 2000px"
          alt=""
        />
      </picture>
    </section>

    <section class="manufacturing-overview" aria-labelledby="manufacturing-title">
      <div class="manufacturing-section-head">
        <h1 id="manufacturing-title">Intelligent<br />Manufacturing</h1>
        <img loading="lazy" decoding="async" width="96" height="32" src="/wp-content/uploads/2024/04/图标-2.png" alt="" />
      </div>
      <p class="manufacturing-label">ARTIFICIAL INTELLIGENCE</p>
      <div class="manufacturing-overview__grid">
        <figure class="manufacturing-overview__image scroll-reveal" data-animate="fadeInUp">
          <img
            loading="lazy"
            decoding="async"
            width="984"
            height="698"
            src="/wp-content/uploads/2024/04/Intelligent-Manufacturing-2.jpg"
            srcset="/wp-content/uploads/2024/04/Intelligent-Manufacturing-2.jpg 984w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-2-300x213.jpg 300w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-2-768x545.jpg 768w"
            sizes="(max-width: 984px) 100vw, 984px"
            alt=""
          />
        </figure>
        <p class="manufacturing-overview__text scroll-reveal" data-animate="fadeInUp">
          Our factory uses real-time data analysis, artificial intelligence (AI), and machine learning in the manufacturing process to realize intelligent manufacturing. The self-developed auto-mated plant improves both production efficiency and cost reduction.
        </p>
      </div>
    </section>

    <section class="manufacturing-highlights" aria-labelledby="manufacturing-highlights-title" data-manufacturing-highlights>
      <div class="manufacturing-section-head">
        <h2 id="manufacturing-highlights-title">Highlights of Automated Plant</h2>
        <img loading="lazy" decoding="async" width="96" height="32" src="/wp-content/uploads/2024/04/图标-2.png" alt="" />
      </div>
      <p class="manufacturing-label">ARTIFICIAL INTELLIGENCE</p>
      <div class="manufacturing-highlights__body">
        <div class="manufacturing-highlight-tabs" data-manufacturing-tabs aria-hidden="true">
          {highlights.map((item) => <span class:list={['manufacturing-highlight-tab', item.num === '01' && 'is-active']}>{item.num}</span>)}
        </div>
        <div class="manufacturing-highlight-list">
          {highlights.map((item) => (
            <article class:list={['manufacturing-highlight', item.num === '01' && 'is-active']} data-manufacturing-highlight>
              <div class="manufacturing-highlight__num">{item.num}</div>
              <div class="manufacturing-highlight__copy">
                <div class="manufacturing-highlight__bar"><span></span></div>
                <h3 set:html={item.heading} />
                <p class="scroll-reveal" data-animate="fadeInUp">{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="manufacturing-gallery" aria-label="Intelligent manufacturing gallery">
      <figure>
        <img
          loading="lazy"
          decoding="async"
          width="1167"
          height="740"
          src="/wp-content/uploads/2024/04/Intelligent-Manufacturing-3.jpg"
          srcset="/wp-content/uploads/2024/04/Intelligent-Manufacturing-3.jpg 1167w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-3-300x190.jpg 300w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-3-1024x649.jpg 1024w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-3-768x487.jpg 768w"
          sizes="(max-width: 1167px) 100vw, 1167px"
          alt=""
        />
      </figure>
      <figure>
        <img
          loading="lazy"
          decoding="async"
          width="1167"
          height="740"
          src="/wp-content/uploads/2024/04/Intelligent-Manufacturing-4.jpg"
          srcset="/wp-content/uploads/2024/04/Intelligent-Manufacturing-4.jpg 1167w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-4-300x190.jpg 300w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-4-1024x649.jpg 1024w, /wp-content/uploads/2024/04/Intelligent-Manufacturing-4-768x487.jpg 768w"
          sizes="(max-width: 1167px) 100vw, 1167px"
          alt=""
        />
      </figure>
    </section>
  </main>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-manufacturing-highlights]');
      if (!root) return;
      const tabs = [...root.querySelectorAll('.manufacturing-highlight-tab')];
      const sections = [...root.querySelectorAll('[data-manufacturing-highlight]')];
      if (!tabs.length || !sections.length) return;

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => tab.classList.toggle('is-active', tabIndex === index));
        sections.forEach((section, sectionIndex) => section.classList.toggle('is-active', sectionIndex === index));
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => {
          activate(index);
          sections[index]?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      });

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (!visible) return;
          const index = sections.indexOf(visible.target);
          if (index >= 0) activate(index);
        },
        { threshold: [0.25, 0.5, 0.75] },
      );
      sections.forEach((section) => observer.observe(section));
    })();
  </script>
</SiteShellLayout>
