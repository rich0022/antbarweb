  { num: '02', heading: 'Higher Effificiency<br>and Lower Cost', text: "Using intelligent manufacturing approach, Antbar's automated manufacturing process drastically decreases the labour cost and time and resource wastage compared to traditional manual assembly methods,and improves production efficiency by more than 50%." },
  { num: '03', heading: 'Process Monitoring<br>and Quality Control', text: 'Automated production stringently monitor the problems that need to be addressed. By collecting and analyzing data, we enable to preview the condition of our production lines.' },
] as const;
