---
import { getCollection } from 'astro:content';
import VerificationLayout from '../layouts/VerificationLayout.astro';

const VERIFICATION_EMBED_URL = 'https://smoant.cn/s/309';

const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === 'verification');
---

<VerificationLayout
  title={entry?.data.title ?? 'ANTBAR-Authenticity Verification:Start your certification now!'}
  description={entry?.data.description ?? 'ANTBAR Authenticity Verification, Start your certification now! Free use!'}
  canonical="/verification/"
  breadcrumbs={[{ name: 'Home', item: '/' }, { name: 'Verification', item: '/verification/' }]}
>
  <main id="content" class="site-main verification-page">
    <section class="verification-frame" aria-label="Authenticity verification">
      <iframe
        class="verification-frame__iframe"
        src={VERIFICATION_EMBED_URL}
        title="Smoant Authentic Verification System"
        loading="eager"
        referrerpolicy="no-referrer-when-downgrade"
      >
        This option will not work correctly. Unfortunately, your browser does not support inline frames.
      </iframe>
    </section>
  </main>
</VerificationLayout>
