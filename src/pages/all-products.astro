---
import { getCollection } from 'astro:content';
import SiteShellLayout from '../layouts/SiteShellLayout.astro';
import { getProductCatalogTabs } from '../lib/product-catalog';
import '../styles/all-products.css';

const pages = await getCollection('pages');
const allEntry = pages.find((p) => p.id === 'all-products');
const productTabs = getProductCatalogTabs();

const bodyClass = 'product-catalog-body';
---

<SiteShellLayout title={allEntry?.data.title ?? 'All Products'} description={allEntry?.data.description ?? ''} bodyClass={bodyClass} canonical="/all-products/" breadcrumbs={[{ name: 'Home', item: '/' }, { name: 'All Products', item: '/all-products/' }]}>
  <main id="content" class="site-main product-catalog-page">
    <section class="product-catalog" aria-labelledby="product-catalog-title">
      <header class="product-catalog__header scroll-reveal" data-animate="fadeInUp">
        <h1 id="product-catalog-title">ANTBAR PRODUCTS</h1>
        <nav class="product-catalog__tabs" aria-label="Product categories">
          {productTabs.map((tab, index) => (
            <button
              class={`product-catalog__tab${index === 0 ? ' is-active' : ''}`}
              type="button"
              data-product-tab={tab.id}
              aria-pressed={index === 0 ? 'true' : 'false'}
            >
              {tab.label}
            </button>
          ))}
        </nav>
      </header>

      <div class="product-catalog__panels scroll-reveal" data-animate="fadeInUp">
        {productTabs.map((tab, index) => (
          <section class="product-catalog__panel" data-product-grid={tab.id} hidden={index !== 0} aria-label={tab.label}>
            <div class="product-catalog__grid" role="list">
              {tab.cards.map((card) => (
                <article class="product-card" role="listitem">
                  <a class="product-card__image-link" href={card.href} aria-label={`View ${card.title}`}>
                    <span class="product-card__image-frame">
                      <img
                        loading="lazy"
                        decoding="async"
                        width={card.image.width}
                        height={card.image.height}
                        src={card.image.src}
                        alt={card.image.alt ?? card.title}
                        srcset={card.image.srcset}
                        sizes={card.image.sizes}
                      />
                    </span>
                  </a>
                  <div class="product-card__body">
                    <h2 class="product-card__title">
                      <a href={card.href}>{card.title}</a>
                    </h2>
                    <a class="product-card__read-more" href={card.href} aria-label={`Read more about ${card.title}`}>
                      View More
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <script is:inline>
      (() => {
        const tabs = document.querySelectorAll('[data-product-tab]');
        const panels = document.querySelectorAll('[data-product-grid]');
        const validTabs = ['all', 'disposable', 'pod-sys'];

        function activateTab(tabId) {
          tabs.forEach((tab) => {
            const isActive = tab.getAttribute('data-product-tab') === tabId;
            tab.classList.toggle('is-active', isActive);
            tab.setAttribute('aria-pressed', String(isActive));
          });
          panels.forEach((panel) => {
            panel.hidden = panel.getAttribute('data-product-grid') !== tabId;
          });
        }

        const params = new URLSearchParams(window.location.search);
        const initialTab = params.get('tab');
        activateTab(validTabs.includes(initialTab) ? initialTab : 'all');

        tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const target = tab.getAttribute('data-product-tab');
            if (validTabs.includes(target)) activateTab(target);
          });
        });
      })();
    </script>
  </main>
</SiteShellLayout>
