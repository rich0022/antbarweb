---
import { getCollection } from 'astro:content';
import SupportLayout from '../layouts/SupportLayout.astro';
import SupportClientScript from '../components/support/SupportClientScript.astro';
import { SUPPORT_FAQS } from '../data/support-faq';

const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === 'support');

const TAB_ID_BASE = 3630;
---

<SupportLayout
  title={entry?.data.title ?? 'Frequently FAQS(Support) | ANTBAR Disposable Vapes Brand'}
  description={entry?.data.description ?? ''}
>
  <main id="content" class="site-main support-page">
    <section class="support-faq" aria-labelledby="support-faq-title">
      <h1 id="support-faq-title" class="support-faq__title scroll-reveal" data-animate="fadeInUp">
        FAQs
      </h1>

      <div class="support-accordion">
        {SUPPORT_FAQS.map((faq) => {
          const titleId = `support-tab-title-${TAB_ID_BASE + faq.tabNumber}`;
          const panelId = `support-tab-panel-${TAB_ID_BASE + faq.tabNumber}`;

          return (
            <article class="support-accordion__item">
              <button
                type="button"
                id={titleId}
                class="support-accordion__trigger"
                data-tab={faq.tabNumber}
                aria-controls={panelId}
                aria-expanded="false"
              >
                <span class="support-accordion__icon" aria-hidden="true">
                  <span class="support-accordion__icon-closed">
                    <svg viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z"></path></svg>
                  </span>
                  <span class="support-accordion__icon-opened">
                    <svg viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z"></path></svg>
                  </span>
                </span>
                <span class="support-accordion__question">{faq.question}</span>
              </button>
              <div
                id={panelId}
                class="support-accordion__panel"
                data-tab={faq.tabNumber}
                role="region"
                aria-labelledby={titleId}
                hidden
              >
                <p>{faq.answer}</p>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  </main>
  <SupportClientScript />
</SupportLayout>
