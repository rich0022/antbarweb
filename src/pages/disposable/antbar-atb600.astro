---
import { getEntry } from 'astro:content';
import ProductLayout from '../../layouts/ProductLayout.astro';
import { ATB600_IMAGES } from '../../data/product-atb600';
import '../../styles/product-atb600.css';

const entry = await getEntry('products', 'disposable/antbar-atb600');
const title = entry?.data.title ?? 'Antbar ATB600|The Best disposable vape Wholesale';
const description = entry?.data.description ?? '';
---

<ProductLayout
  title={title}
  description={description}
  bodyClass="product-page-body product-atb600-body"
>
  <main id="content" class="site-main product-atb600" aria-label="ATB600 product details">
    {
      ATB600_IMAGES.map((image, index) => (
        <img
          class:list={[
            'product-atb600__image',
            'scroll-reveal',
            image.spacedTop && 'product-atb600__image--spaced',
          ]}
          src={image.src}
          width={image.width}
          height={image.height}
          alt={image.alt}
          loading={index === 0 ? 'eager' : 'lazy'}
          decoding="async"
          data-animate="fadeInUp"
        />
      ))
    }
  </main>
</ProductLayout>
