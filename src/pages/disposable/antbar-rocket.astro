---
import { getEntry } from 'astro:content';
import ProductLayout from '../../layouts/ProductLayout.astro';
import ProductMediaPanel from '../../components/product/ProductMediaPanel.astro';
import {
  ROCKET_FLAVORS,
  ROCKET_HERO,
  ROCKET_HIGHLIGHTS,
  ROCKET_PACKAGING,
  ROCKET_SHOWCASE_IMAGE,
  ROCKET_SPEC,
  ROCKET_STORIES,
} from '../../data/product-rocket';
import '../../styles/product-rocket.css';

const entry = await getEntry('products', 'disposable/antbar-rocket');
const title = entry?.data.seo?.title ?? entry?.data.title ?? 'ROCKET Disposable Vape-ANTBAR';
const description = entry?.data.seo?.description ?? entry?.data.description ?? '';
const canonicalOverride = entry?.data.seo?.canonical;
---

<ProductLayout
  title={title}
  description={description}
  bodyClass="product-page-body product-rocket-body"
  canonical={canonicalOverride ?? "/disposable/antbar-rocket/"}
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'Products', item: '/all-products/' },
    { name: 'ROCKET', item: '/disposable/antbar-rocket/' },
  ]}
  jsonProduct={{
    name: 'ROCKET',
    description: description,
    brand: 'ANTBAR',
  }}
>
  <main id="content" class="site-main product-page product-rocket">
    <section
      class="product-rocket__hero scroll-reveal"
      aria-labelledby="rocket-hero-title"
      data-animate="fadeInUp"
    >
      <img
        class="product-rocket__hero-bg"
        src={ROCKET_HERO.image}
        width={ROCKET_HERO.width}
        height={ROCKET_HERO.height}
        alt=""
        loading="eager"
        decoding="async"
      />
      <div class="product-rocket__hero-overlay">
        <div class="product-rocket__hero-copy">
          <h1 id="rocket-hero-title" class="product-page__heading-hero">
            {ROCKET_HERO.title}
          </h1>
          <p class="product-page__tagline">{ROCKET_HERO.subtitle}</p>
          <a class="product-rocket__spec-link" href={ROCKET_HERO.specHref}>
            Specifications &gt;
          </a>
        </div>
      </div>
    </section>

    <section class="product-rocket__highlights scroll-reveal" data-animate="fadeInUp">
      <h2 class="product-page__heading-section">{ROCKET_HIGHLIGHTS.heading}</h2>
      <p class="product-page__text">{ROCKET_HIGHLIGHTS.description}</p>
    </section>

    <section class="scroll-reveal" aria-hidden="true" data-animate="fadeInUp">
      <img
        class="product-rocket__showcase-image"
        src={ROCKET_SHOWCASE_IMAGE.src}
        width={ROCKET_SHOWCASE_IMAGE.width}
        height={ROCKET_SHOWCASE_IMAGE.height}
        alt=""
        loading="lazy"
        decoding="async"
      />
    </section>

    {
      ROCKET_STORIES.map((story, index) => (
        <ProductMediaPanel
          classPrefix="product-rocket"
          image={story.image}
          width={story.width}
          height={story.height}
          heading={story.heading}
          headingHtml={story.headingHtml}
          description={story.description}
          position={story.position}
          loading={index === 0 ? 'eager' : 'lazy'}
        />
      ))
    }

    <section class="product-rocket__flavors scroll-reveal" data-animate="fadeInUp">
      <h2 class="product-page__heading-section">{ROCKET_FLAVORS.heading}</h2>
      <p class="product-page__text" set:html={ROCKET_FLAVORS.description} />
      <img
        class="product-rocket__flavors-image"
        src={ROCKET_FLAVORS.image.src}
        width={ROCKET_FLAVORS.image.width}
        height={ROCKET_FLAVORS.image.height}
        alt={ROCKET_FLAVORS.image.alt}
        loading="lazy"
        decoding="async"
      />
    </section>

    <h2
      id="specfication"
      class="product-rocket__spec-heading scroll-reveal"
      data-animate="fadeInUp"
    >
      {ROCKET_SPEC.heading}
    </h2>

    <section class="scroll-reveal" aria-labelledby="specfication" data-animate="fadeInUp">
      <img
        class="product-rocket__spec-image"
        src={ROCKET_SPEC.image.src}
        width={ROCKET_SPEC.image.width}
        height={ROCKET_SPEC.image.height}
        alt=""
        loading="lazy"
        decoding="async"
      />
    </section>

    <ProductMediaPanel
      classPrefix="product-rocket"
      image={ROCKET_PACKAGING.image}
      width={ROCKET_PACKAGING.width}
      height={ROCKET_PACKAGING.height}
      heading={ROCKET_PACKAGING.heading}
      position="top-left"
    />
  </main>
</ProductLayout>
