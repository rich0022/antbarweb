---
import { getCollection } from 'astro:content';
import ContentBody from '../../components/ContentBody.astro';
import ProductLayout from '../../layouts/ProductLayout.astro';
import { readContentBody } from '../../lib/content-body';
import { contentEntryFileName } from '../../lib/content-entry';
import { resolveMirrorRoute } from '../../lib/mirror-assets';

const products = await getCollection('products');
const categoryEntry = products.find(
  (entry) =>
    entry.id === 'disposable/index' || entry.id === 'disposable' || entry.data.slug === 'disposable',
);
const bodyHtml = categoryEntry
  ? await readContentBody('products', contentEntryFileName(categoryEntry.id, 'products'))
  : '';
const mirrorRoute = categoryEntry
  ? resolveMirrorRoute('products', contentEntryFileName(categoryEntry.id, 'products'))
  : 'disposable';
---

<ProductLayout
  title={categoryEntry?.data.title ?? 'Disposable Products'}
  description={categoryEntry?.data.description}
  mirrorRoute={mirrorRoute}
>
  <ContentBody html={bodyHtml} />
</ProductLayout>
