---
import { getEntry } from 'astro:content';
import ProductLayout from '../../layouts/ProductLayout.astro';
import {
  AGP12000_BATTERY_PANEL,
  AGP12000_COMPACT_PANEL,
  AGP12000_FEATURE_GRID,
  AGP12000_FLAVORS,
  AGP12000_HERO,
  AGP12000_LIQUID_SPLIT,
  AGP12000_MESH_SECTION,
  AGP12000_PACKAGE,
  AGP12000_SHOWCASE_VIDEOS,
  AGP12000_SPEC,
  AGP12000_VIDEO,
} from '../../data/product-agp12000';
import '../../styles/product-agp12000.css';

const entry = await getEntry('products', 'disposable/agp12000-nicotine-disposable-vape');
const title = entry?.data.title ?? 'AGP12000 Disposable Vape 14ML/12000 Puffs-ANTBAR';
const description = entry?.data.description ?? '';
const dripTipsFeature = AGP12000_FEATURE_GRID.row1[0];
const batteryFeature = AGP12000_FEATURE_GRID.row1[1];
const liquidFeature = AGP12000_FEATURE_GRID.row2[0];
const ledMeshFeatures = Array.isArray(AGP12000_FEATURE_GRID.row2[1]) ? AGP12000_FEATURE_GRID.row2[1] : [];
const compactFeature = AGP12000_FEATURE_GRID.row2[2];
---

<ProductLayout
  title={title}
  description={description}
  bodyClass="product-page-body product-agp12000-body"
>
  <main id="content" class="site-main product-page product-agp12000">
    <section
      class="product-agp12000__hero scroll-reveal"
      aria-labelledby="agp12000-hero-title"
      data-animate="fadeInUp"
    >
      <img
        class="product-agp12000__hero-bg"
        src={AGP12000_HERO.image}
        width={AGP12000_HERO.width}
        height={AGP12000_HERO.height}
        alt=""
        loading="eager"
        decoding="async"
      />
      <div class="product-agp12000__hero-overlay">
        <div class="product-agp12000__hero-copy">
          <h1 id="agp12000-hero-title" class="product-page__heading-hero">
            {AGP12000_HERO.title}
          </h1>
          <p class="product-page__tagline">{AGP12000_HERO.tagline}</p>
          <a class="product-agp12000__spec-link" href={AGP12000_HERO.specHref}>
            <img
              src={AGP12000_HERO.specButton.src}
              width={AGP12000_HERO.specButton.width}
              height={AGP12000_HERO.specButton.height}
              alt={AGP12000_HERO.specButton.alt}
              loading="eager"
              decoding="async"
            />
          </a>
        </div>
      </div>
    </section>

    <section class="product-agp12000__video scroll-reveal" aria-label="Product video preview" data-animate="fadeInUp">
      <video
        id="agp12000-video-bg"
        class="product-agp12000__video-element"
        src={AGP12000_VIDEO.background}
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      />
      <div class="product-agp12000__video-mask" aria-hidden="true"></div>
      <button
        type="button"
        class="product-agp12000__play-btn"
        id="agp12000-play-btn"
        aria-haspopup="dialog"
        aria-controls="agp12000-video-modal"
        aria-label="Play product video"
      >
        <svg viewBox="0 0 448 512" aria-hidden="true">
          <path
            d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"
          ></path>
        </svg>
        PLAY
      </button>
    </section>

    <div
      id="agp12000-video-modal"
      class="product-agp12000__modal"
      role="dialog"
      aria-modal="true"
      aria-label="Product video"
      hidden
    >
      <button
        type="button"
        class="product-agp12000__modal-backdrop"
        id="agp12000-modal-backdrop"
        aria-label="Close video"
      ></button>
      <div class="product-agp12000__modal-dialog">
        <button
          type="button"
          class="product-agp12000__modal-close"
          id="agp12000-modal-close"
          aria-label="Close video"
        >
          ×
        </button>
        <video
          id="agp12000-video-player"
          class="product-agp12000__modal-video"
          src={AGP12000_VIDEO.modal}
          controls
          playsinline
          preload="metadata"
        />
      </div>
    </div>

    <section class="product-agp12000__features scroll-reveal" aria-label="Product features" data-animate="fadeInUp">
      <div class="product-agp12000__feature-layout">
        <div class="product-agp12000__feature-column product-agp12000__feature-column--primary">
          <article
            class="product-agp12000__feature-card product-agp12000__feature-card--drip-tips"
            style={`background-image: url(${dripTipsFeature.background})`}
          >
            <h2 class="product-agp12000__feature-heading" set:html={dripTipsFeature.headingHtml} />
            {'tips' in dripTipsFeature && dripTipsFeature.tips && (
              <div class="product-agp12000__feature-tips">
                {dripTipsFeature.tips.map((tip) => (
                  <div class="product-agp12000__feature-tip">
                    <img
                      src={tip.image}
                      width={tip.width}
                      height={tip.height}
                      alt=""
                      loading="lazy"
                      decoding="async"
                    />
                    <p class="product-agp12000__feature-tip-label" set:html={tip.labelHtml} />
                  </div>
                ))}
              </div>
            )}
          </article>

          <article
            class="product-agp12000__feature-card product-agp12000__feature-card--battery"
            style={`background-image: url(${batteryFeature.background})`}
          >
            <h2 class="product-agp12000__feature-heading" set:html={batteryFeature.headingHtml} />
          </article>
        </div>

        <div class="product-agp12000__feature-column product-agp12000__feature-column--secondary">
          <article
            class="product-agp12000__feature-card product-agp12000__feature-card--liquid"
            style={`background-image: url(${liquidFeature.background})`}
          >
            <h2 class="product-agp12000__feature-heading" set:html={liquidFeature.headingHtml} />
          </article>

          <div class="product-agp12000__feature-mini-row">
            {ledMeshFeatures.map((card) => (
              <article
                class="product-agp12000__feature-card product-agp12000__feature-card--mini"
                style={`background-image: url(${card.background})`}
              >
                <h2 class="product-agp12000__feature-heading" set:html={card.headingHtml} />
                {'badge' in card && card.badge && (
                  <img
                    class="product-agp12000__feature-badge"
                    src={card.badge.src}
                    width={card.badge.width}
                    height={card.badge.height}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </article>
            ))}
          </div>

          <article
            class="product-agp12000__feature-card product-agp12000__feature-card--compact"
            style={`background-image: url(${compactFeature.background})`}
          >
            <h2 class="product-agp12000__feature-heading" set:html={compactFeature.headingHtml} />
          </article>
        </div>
      </div>
    </section>

    <section class="product-agp12000__showcase-videos scroll-reveal" aria-hidden="true" data-animate="fadeInUp">
      {
        AGP12000_SHOWCASE_VIDEOS.map((src) => (
          <video
            class="product-agp12000__showcase-video"
            src={src}
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
          />
        ))
      }
    </section>

    <section class="product-agp12000__split scroll-reveal" data-animate="fadeInUp">
      <div class="product-agp12000__split-copy">
        <h2 class="product-agp12000__split-heading">{AGP12000_LIQUID_SPLIT.heading}</h2>
        <p class="product-agp12000__split-text">{AGP12000_LIQUID_SPLIT.description}</p>
      </div>
      <figure class="product-agp12000__split-figure">
        <img
          src={AGP12000_LIQUID_SPLIT.image.src}
          width={AGP12000_LIQUID_SPLIT.image.width}
          height={AGP12000_LIQUID_SPLIT.image.height}
          alt={AGP12000_LIQUID_SPLIT.image.alt}
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>

    <section class="product-agp12000__panel scroll-reveal" data-animate="fadeInUp">
      <img
        class="product-agp12000__panel-bg"
        src={AGP12000_COMPACT_PANEL.image}
        width={AGP12000_COMPACT_PANEL.width}
        height={AGP12000_COMPACT_PANEL.height}
        alt=""
        loading="lazy"
        decoding="async"
      />
      <div class="product-agp12000__panel-overlay">
        <div class="product-agp12000__panel-copy">
          <h2 class="product-agp12000__split-heading">{AGP12000_COMPACT_PANEL.heading}</h2>
          <p class="product-agp12000__split-text">{AGP12000_COMPACT_PANEL.description}</p>
        </div>
        <figure class="product-agp12000__split-figure">
          <img
            src={AGP12000_COMPACT_PANEL.productImage.src}
            width={AGP12000_COMPACT_PANEL.productImage.width}
            height={AGP12000_COMPACT_PANEL.productImage.height}
            alt=""
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </section>

    <section class="product-agp12000__mesh scroll-reveal" data-animate="fadeInUp">
      <h2 class="product-agp12000__mesh-heading">{AGP12000_MESH_SECTION.heading}</h2>
      <img
        class="product-agp12000__mesh-image"
        src={AGP12000_MESH_SECTION.image.src}
        width={AGP12000_MESH_SECTION.image.width}
        height={AGP12000_MESH_SECTION.image.height}
        alt={AGP12000_MESH_SECTION.image.alt}
        loading="lazy"
        decoding="async"
      />
      <div class="product-agp12000__mesh-footer">
        {
          AGP12000_MESH_SECTION.cards.map((card) => (
            <article
              class="product-agp12000__mesh-card"
              style={`background-image: url(${card.background})`}
            >
              <h3 class="product-agp12000__mesh-card-heading" set:html={card.headingHtml} />
            </article>
          ))
        }
        <p class="product-agp12000__mesh-text">{AGP12000_MESH_SECTION.description}</p>
      </div>
    </section>

    <section class="product-agp12000__battery scroll-reveal" data-animate="fadeInUp">
      <img
        class="product-agp12000__battery-bg"
        src={AGP12000_BATTERY_PANEL.image}
        width={AGP12000_BATTERY_PANEL.width}
        height={AGP12000_BATTERY_PANEL.height}
        alt=""
        loading="lazy"
        decoding="async"
      />
      <div class="product-agp12000__battery-overlay">
        <div class="product-agp12000__battery-copy">
          <h2 class="product-agp12000__split-heading">{AGP12000_BATTERY_PANEL.heading}</h2>
          <p class="product-agp12000__split-text" set:html={AGP12000_BATTERY_PANEL.descriptionHtml} />
        </div>
      </div>
    </section>

    <section class="product-agp12000__flavors scroll-reveal" data-animate="fadeInUp">
      <h2 class="product-agp12000__flavors-heading">{AGP12000_FLAVORS.heading}</h2>
      {
        AGP12000_FLAVORS.rows.map((row) => (
          <div class="product-agp12000__flavors-grid">
            {row.map((card) => (
              <article class="product-agp12000__flavor-card">
                <img src={card.image} width={385} height={548} alt="" loading="lazy" decoding="async" />
                <h3 class="product-agp12000__flavor-title">{card.title}</h3>
              </article>
            ))}
          </div>
        ))
      }
    </section>

    <section
      id="specification"
      class="product-agp12000__spec scroll-reveal"
      aria-labelledby="agp12000-spec-title"
      data-animate="fadeInUp"
    >
      <h2 id="agp12000-spec-title" class="product-agp12000__spec-heading">
        {AGP12000_SPEC.heading}
      </h2>
      <div class="product-agp12000__spec-grid">
        <div class="product-agp12000__spec-product">
          <img
            src={AGP12000_SPEC.productImage.src}
            width={AGP12000_SPEC.productImage.width}
            height={AGP12000_SPEC.productImage.height}
            alt={AGP12000_SPEC.productImage.alt}
            loading="lazy"
            decoding="async"
          />
        </div>
        {
          AGP12000_SPEC.columns.map((column) => (
            <div class="product-agp12000__spec-column">
              {column.map((image) => (
                <img
                  src={image.src}
                  width={image.width}
                  height={image.height}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
              ))}
            </div>
          ))
        }
      </div>
    </section>

    <section class="product-agp12000__package scroll-reveal" aria-labelledby="agp12000-package-title" data-animate="fadeInUp">
      <img
        class="product-agp12000__package-bg"
        src={AGP12000_PACKAGE.image}
        width={AGP12000_PACKAGE.width}
        height={AGP12000_PACKAGE.height}
        alt=""
        loading="lazy"
        decoding="async"
      />
      <div class="product-agp12000__package-overlay">
        <h2 id="agp12000-package-title" class="product-agp12000__package-heading">
          {AGP12000_PACKAGE.heading}
        </h2>
      </div>
    </section>
  </main>

  <script>
    const bgVideo = document.getElementById('agp12000-video-bg');
    const modal = document.getElementById('agp12000-video-modal');
    const modalVideo = document.getElementById('agp12000-video-player');
    const playBtn = document.getElementById('agp12000-play-btn');
    const closeBtn = document.getElementById('agp12000-modal-close');
    const backdrop = document.getElementById('agp12000-modal-backdrop');

    function openModal() {
      if (
        !(modal instanceof HTMLDivElement) ||
        !(modalVideo instanceof HTMLVideoElement) ||
        !(bgVideo instanceof HTMLVideoElement)
      ) {
        return;
      }

      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      bgVideo.pause();
      modalVideo.currentTime = 0;
      void modalVideo.play();
    }

    function closeModal() {
      if (
        !(modal instanceof HTMLDivElement) ||
        !(modalVideo instanceof HTMLVideoElement) ||
        !(bgVideo instanceof HTMLVideoElement)
      ) {
        return;
      }

      modal.hidden = true;
      document.body.style.overflow = '';
      modalVideo.pause();
      void bgVideo.play();
    }

    playBtn?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal instanceof HTMLDivElement && !modal.hidden) {
        closeModal();
      }
    });
  </script>
</ProductLayout>
