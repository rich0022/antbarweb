---
import { getEntry } from 'astro:content';
import ProductLayout from '../../layouts/ProductLayout.astro';
import ProductFeatureCard from '../../components/product/ProductFeatureCard.astro';
import ProductMediaStory from '../../components/product/ProductMediaStory.astro';
import {
  SA8000_FEATURE_ROW_1,
  SA8000_FEATURE_ROW_2,
  SA8000_FLAVORS_NEW,
  SA8000_FLAVORS_PRIMARY,
  SA8000_HERO,
  SA8000_SPEC,
  SA8000_STORIES,
  SA8000_VIDEO,
  SA8000_WARNING,
} from '../../data/product-sa8000';
import '../../styles/product-sa8000.css';

const entry = await getEntry('products', 'disposable/antbar-sa8000');
const title = entry?.data.title ?? 'SA8000 Rechargeable Disposable Vape 8000 Puffs-ANTBAR';
const description = entry?.data.description ?? '';
---

<ProductLayout
  title={title}
  description={description}
  bodyClass="product-page-body product-sa8000-body"
>
  <main id="content" class="site-main product-page product-sa8000">
    <section
      class="product-sa8000__media scroll-reveal"
      aria-labelledby="sa8000-hero-title"
      data-animate="fadeInUp"
    >
      <img
        class="product-sa8000__media-bg"
        src={SA8000_HERO.background}
        width={SA8000_HERO.width}
        height={SA8000_HERO.height}
        alt=""
        loading="eager"
        decoding="async"
      />
      <div class="product-sa8000__media-overlay product-sa8000__hero-overlay">
        <div class="product-sa8000__hero-content">
          <h1 id="sa8000-hero-title" class="product-page__heading-hero">
            {SA8000_HERO.title}
          </h1>
          <p class="product-page__tagline">{SA8000_HERO.subtitle}</p>
          <a class="product-sa8000__spec-link" href={SA8000_HERO.specHref}>
            <img
              src={SA8000_HERO.specButton.src}
              width={SA8000_HERO.specButton.width}
              height={SA8000_HERO.specButton.height}
              alt={SA8000_HERO.specButton.alt}
              loading="eager"
              decoding="async"
            />
          </a>
        </div>
      </div>
    </section>

    <div class="product-sa8000__showcase scroll-reveal" data-animate="fadeInUp">
      <section class="product-sa8000__video" aria-label="Product video preview">
        <video
          id="sa8000-video-bg"
          class="product-sa8000__video-element"
          src={SA8000_VIDEO.background}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        />
        <div class="product-sa8000__video-mask" aria-hidden="true"></div>
        <button
          type="button"
          class="product-sa8000__play-btn"
          id="sa8000-play-btn"
          aria-haspopup="dialog"
          aria-controls="sa8000-video-modal"
          aria-label="Play product video"
        >
          <svg viewBox="0 0 448 512" aria-hidden="true">
            <path
              d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"
            ></path>
          </svg>
          PLAY
        </button>
      </section>

      <section class="product-sa8000__features" aria-label="Product features">
        <div class="product-sa8000__feature-row product-sa8000__feature-row--top">
          {
            SA8000_FEATURE_ROW_1.map((card) => (
              <ProductFeatureCard {...card} equalHeight />
            ))
          }
        </div>
        <div class="product-sa8000__feature-row product-sa8000__feature-row--bottom">
          {SA8000_FEATURE_ROW_2.map((card) => <ProductFeatureCard {...card} />)}
        </div>
      </section>
    </div>

    <div
      id="sa8000-video-modal"
      class="product-sa8000__modal"
      role="dialog"
      aria-modal="true"
      aria-label="Product video"
      hidden
    >
      <button
        type="button"
        class="product-sa8000__modal-backdrop"
        id="sa8000-modal-backdrop"
        aria-label="Close video"
      ></button>
      <div class="product-sa8000__modal-dialog">
        <button
          type="button"
          class="product-sa8000__modal-close"
          id="sa8000-modal-close"
          aria-label="Close video"
        >
          ×
        </button>
        <video
          id="sa8000-video-player"
          class="product-sa8000__modal-video"
          src={SA8000_VIDEO.modal}
          controls
          playsinline
          preload="metadata"
        />
      </div>
    </div>

    <section
      class="product-sa8000__flavors product-sa8000__flavors--primary scroll-reveal"
      data-animate="fadeInUp"
    >
      <div class="product-sa8000__flavors-header">
        <h2 class="product-page__heading-section">{SA8000_FLAVORS_PRIMARY.heading}</h2>
        <img
          class="product-sa8000__flavors-badge"
          src={SA8000_FLAVORS_PRIMARY.badge}
          width={SA8000_FLAVORS_PRIMARY.badgeWidth}
          height={SA8000_FLAVORS_PRIMARY.badgeHeight}
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
      <img
        class="product-sa8000__flavors-image"
        src={SA8000_FLAVORS_PRIMARY.image}
        width={SA8000_FLAVORS_PRIMARY.imageWidth}
        height={SA8000_FLAVORS_PRIMARY.imageHeight}
        alt=""
        loading="lazy"
        decoding="async"
      />
    </section>

    <section
      class="product-sa8000__flavors product-sa8000__flavors--new scroll-reveal"
      data-animate="fadeInUp"
    >
      <div class="product-sa8000__flavors-header">
        <img
          class="product-sa8000__flavors-badge"
          src={SA8000_FLAVORS_NEW.badge}
          width={SA8000_FLAVORS_NEW.badgeWidth}
          height={SA8000_FLAVORS_NEW.badgeHeight}
          alt=""
          loading="lazy"
          decoding="async"
        />
        <h2 class="product-page__heading-section">{SA8000_FLAVORS_NEW.heading}</h2>
      </div>
      {
        SA8000_FLAVORS_NEW.images.map((image) => (
          <img
            class="product-sa8000__flavors-image"
            src={image.src}
            width={image.width}
            height={image.height}
            alt=""
            loading="lazy"
            decoding="async"
          />
        ))
      }
    </section>

    {SA8000_STORIES.map((story) => <ProductMediaStory {...story} />)}

    <section
      id="specfication"
      class="product-sa8000__spec scroll-reveal"
      aria-labelledby="sa8000-spec-title"
      data-animate="fadeInUp"
    >
      <h2 id="sa8000-spec-title" class="product-sa8000__spec-heading">
        {SA8000_SPEC.heading}
      </h2>
      <div class="product-sa8000__spec-grid">
        <div class="product-sa8000__spec-product">
          <img
            src={SA8000_SPEC.productImage.src}
            width={SA8000_SPEC.productImage.width}
            height={SA8000_SPEC.productImage.height}
            alt={SA8000_SPEC.productImage.alt}
            loading="lazy"
            decoding="async"
          />
        </div>
        {
          SA8000_SPEC.columns.map((column) => (
            <div class="product-sa8000__spec-column">
              {column.map((image) => (
                <img
                  src={image.src}
                  width={image.width}
                  height={image.height}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
              ))}
            </div>
          ))
        }
      </div>
    </section>

    <section class="scroll-reveal" aria-hidden="true" data-animate="fadeInUp">
      <img
        class="product-sa8000__warning-image"
        src={SA8000_WARNING.image}
        width={SA8000_WARNING.width}
        height={SA8000_WARNING.height}
        alt=""
        loading="lazy"
        decoding="async"
      />
    </section>
  </main>

  <script>
    const bgVideo = document.getElementById('sa8000-video-bg');
    const modal = document.getElementById('sa8000-video-modal');
    const modalVideo = document.getElementById('sa8000-video-player');
    const playBtn = document.getElementById('sa8000-play-btn');
    const closeBtn = document.getElementById('sa8000-modal-close');
    const backdrop = document.getElementById('sa8000-modal-backdrop');

    function openModal() {
      if (
        !(modal instanceof HTMLDivElement) ||
        !(modalVideo instanceof HTMLVideoElement) ||
        !(bgVideo instanceof HTMLVideoElement)
      ) {
        return;
      }

      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      bgVideo.pause();
      modalVideo.currentTime = 0;
      void modalVideo.play();
    }

    function closeModal() {
      if (
        !(modal instanceof HTMLDivElement) ||
        !(modalVideo instanceof HTMLVideoElement) ||
        !(bgVideo instanceof HTMLVideoElement)
      ) {
        return;
      }

      modal.hidden = true;
      document.body.style.overflow = '';
      modalVideo.pause();
      void bgVideo.play();
    }

    if (playBtn instanceof HTMLButtonElement) {
      playBtn.addEventListener('click', openModal);
    }

    if (closeBtn instanceof HTMLButtonElement) {
      closeBtn.addEventListener('click', closeModal);
    }

    if (backdrop instanceof HTMLButtonElement) {
      backdrop.addEventListener('click', closeModal);
    }

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal instanceof HTMLDivElement && !modal.hidden) {
        closeModal();
      }
    });
  </script>
</ProductLayout>
