---
import { getCollection } from 'astro:content';
import ContentBody from '../components/ContentBody.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { readContentBody } from '../lib/content-body';
import { contentEntryFileName, contentEntrySlug } from '../lib/content-entry';
import { resolveMirrorRoute } from '../lib/mirror-assets';

export async function getStaticPaths() {
  const staticPages = await getCollection('pages');
  const excluded = ['home','pod-sys','about-us','brand-story','rd-center','antbar-lab','intelligent-manufacturing','contact','support','verification','all-products','privacy-policy'];
  return staticPages
    .filter((entry) => !excluded.includes(entry.id))
    .map((entry) => ({
      params: { page: contentEntrySlug(entry.id, 'pages') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const bodyHtml = await readContentBody('pages', contentEntryFileName(entry.id, 'pages'));
const mirrorRoute = resolveMirrorRoute('pages', contentEntryFileName(entry.id, 'pages'));

const title = entry.data.seo?.title ?? entry.data.title;
const description = entry.data.seo?.description ?? entry.data.description ?? '';
const canonicalOverride = entry.data.seo?.canonical;
---

<BaseLayout title={title} description={description} mirrorRoute={mirrorRoute} canonical={canonicalOverride}>
  <ContentBody html={bodyHtml} />
</BaseLayout>
