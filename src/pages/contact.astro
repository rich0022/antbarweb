---
import { getCollection } from 'astro:content';
import ContactLayout from '../layouts/ContactLayout.astro';
import { CONTACT_TURNSTILE_SITE_KEY } from '../data/contact';

const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === 'contact');
---

<ContactLayout
  title={entry?.data.title ?? 'Contact To E-Cigarette Wholesale Company |ANTBAR'}
  description={entry?.data.description ?? ''}
>
  <main id="content" class="site-main contact-page">
    <section class="contact-form-section" aria-labelledby="contact-form-title">
      <h1
        id="contact-form-title"
        class="contact-form-section__title scroll-reveal"
        data-animate="fadeInUp"
      >
        Contact Us
      </h1>

      <form
        class="contact-form scroll-reveal"
        id="contact-form"
        method="post"
        action="/contact"
        name="Contact form"
        aria-label="Contact form"
        data-animate="fadeInUp"
      >
        <div class="contact-form__fields">
          <div class="contact-form__field">
            <label class="contact-form__label--sr-only" for="contact-name">Name</label>
            <input
              class="contact-form__input"
              type="text"
              name="name"
              id="contact-name"
              placeholder="Your Name"
              autocomplete="name"
            />
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label--sr-only" for="contact-email">Email</label>
            <input
              class="contact-form__input"
              type="email"
              name="email"
              id="contact-email"
              placeholder="Your E-mail"
              required
              autocomplete="email"
            />
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label--sr-only" for="contact-message">Message</label>
            <textarea
              class="contact-form__textarea"
              name="message"
              id="contact-message"
              rows="4"
              placeholder="Your Message"
            ></textarea>
          </div>

          <div class="contact-form__field contact-form__field--turnstile">
            <div class="cf-turnstile" data-sitekey={CONTACT_TURNSTILE_SITE_KEY} data-theme="light"></div>
          </div>

          <div class="contact-form__actions">
            <button class="contact-form__submit" type="submit">Submit</button>
          </div>
          <p class="contact-form__status" data-contact-status hidden></p>
        </div>
      </form>
    </section>
  </main>
</ContactLayout>

<script is:inline>
  (() => {
    const script = document.createElement('script');
    script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
    script.async = true;
    script.defer = true;
    document.head.appendChild(script);

    const form = document.getElementById('contact-form');
    const statusEl = document.querySelector('[data-contact-status]');
    if (!form || !statusEl) return;

    const setStatus = (msg, ok) => {
      statusEl.textContent = msg;
      statusEl.hidden = false;
      statusEl.style.color = ok ? '#008000' : '#cc0000';
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;
      setStatus('Sending...', true);

      try {
        const data = new URLSearchParams(new FormData(form));
        const resp = await fetch('/contact', { method: 'POST', body: data });
        const result = await resp.json();

        if (resp.ok && result.success) {
          setStatus('Thank you! Your message has been sent.', true);
          form.reset();
          // Reset Turnstile widget
          const turnstileWidget = form.querySelector('.cf-turnstile');
          if (turnstileWidget && window.turnstile) {
            window.turnstile.reset(turnstileWidget);
          }
        } else {
          setStatus(result.error || 'Failed to send. Please try again.', false);
        }
      } catch {
        setStatus('Network error. Please check your connection.', false);
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  })();
</script>
