---
import { getCollection } from 'astro:content';
import ContactLayout from '../layouts/ContactLayout.astro';
import ContactClientScript from '../components/contact/ContactClientScript.astro';
import { CONTACT_RECAPTCHA_SITE_KEY } from '../data/contact';

const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === 'contact');
---

<ContactLayout
  title={entry?.data.title ?? 'Contact To E-Cigarette Wholesale Company |ANTBAR'}
  description={entry?.data.description ?? ''}
>
  <main id="content" class="site-main contact-page">
    <section class="contact-form-section" aria-labelledby="contact-form-title">
      <h1
        id="contact-form-title"
        class="contact-form-section__title scroll-reveal"
        data-animate="fadeInUp"
      >
        Contact Us
      </h1>

      <form
        class="contact-form scroll-reveal"
        id="contact-form"
        method="post"
        name="Contact form"
        aria-label="Contact form"
        data-animate="fadeInUp"
      >
        <div class="contact-form__fields">
          <div class="contact-form__field">
            <label class="contact-form__label--sr-only" for="contact-name">Send E-mail</label>
            <input
              class="contact-form__input"
              type="text"
              name="name"
              id="contact-name"
              placeholder="Your Name"
              autocomplete="name"
            />
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label--sr-only" for="contact-email">Email</label>
            <input
              class="contact-form__input"
              type="email"
              name="email"
              id="contact-email"
              placeholder="Your E-mail"
              required
              autocomplete="email"
            />
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label--sr-only" for="contact-message">Message</label>
            <textarea
              class="contact-form__textarea"
              name="message"
              id="contact-message"
              rows="4"
              placeholder="Your Message"
            ></textarea>
          </div>

          <div class="contact-form__field contact-form__field--recaptcha">
            <div class="contact-form__recaptcha" id="contact-recaptcha" aria-hidden="true"></div>
          </div>

          <div class="contact-form__actions">
            <button class="contact-form__submit" type="submit">Submit</button>
          </div>
        </div>
      </form>
    </section>
  </main>
  <ContactClientScript />
</ContactLayout>

<script define:vars={{ siteKey: CONTACT_RECAPTCHA_SITE_KEY }} is:inline>
  // reCAPTCHA v3 badge (invisible) — matches live antbar.com contact page behavior.
  window.addEventListener('load', () => {
    if (typeof grecaptcha === 'undefined') return;
    grecaptcha.ready(() => {
      grecaptcha.execute(siteKey, { action: 'Form' });
    });
  });
</script>
