---
import { getCollection } from 'astro:content';
import ContactLayout from '../layouts/ContactLayout.astro';

const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === 'contact');

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
const contactEndpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT || '/api/contact/';
const missingSiteKey = !turnstileSiteKey;
---

<ContactLayout
  title={entry?.data.title ?? 'Contact To E-Cigarette Wholesale Company |ANTBAR'}
  description={entry?.data.description ?? ''}
  canonical="/contact/"
  breadcrumbs={[{ name: 'Home', item: '/' }, { name: 'Contact', item: '/contact/' }]}
>
  <main id="content" class="site-main contact-page">
    <section class="contact-form-section" aria-labelledby="contact-form-title">
      <h1
        id="contact-form-title"
        class="contact-form-section__title scroll-reveal"
        data-animate="fadeInUp"
      >
        Contact Us
      </h1>

      {
        missingSiteKey && import.meta.env.PROD && (
          <p class="contact-form__config-warning">
            Contact form security is not configured. Set PUBLIC_TURNSTILE_SITE_KEY in wrangler.jsonc,
            then rebuild and redeploy.
          </p>
        )
      }

      <form
        class="contact-form scroll-reveal"
        id="contact-form"
        method="post"
        action={contactEndpoint}
        name="Contact form"
        aria-label="Contact form"
        data-animate="fadeInUp"
        data-contact-form
      >
        <div class="contact-form__fields">
          <div class="contact-form__field">
            <label class="contact-form__label--sr-only" for="contact-name">Name</label>
            <input
              class="contact-form__input"
              type="text"
              name="name"
              id="contact-name"
              placeholder="Your Name"
              autocomplete="name"
            />
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label--sr-only" for="contact-email">Email</label>
            <input
              class="contact-form__input"
              type="email"
              name="email"
              id="contact-email"
              placeholder="Your E-mail"
              required
              autocomplete="email"
            />
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label--sr-only" for="contact-message">Message</label>
            <textarea
              class="contact-form__textarea"
              name="message"
              id="contact-message"
              rows="4"
              placeholder="Your Message"
              required
            ></textarea>
          </div>

          <input
            class="contact-form__hp-field"
            type="text"
            name="website"
            autocomplete="off"
            tabindex="-1"
            aria-hidden="true"
          />

          {
            turnstileSiteKey && (
              <>
                <script is:inline>
                  window.__turnstileOnSuccess = function (token) {
                    document.querySelectorAll('[data-contact-form]').forEach((form) => {
                      const field = form.querySelector('[data-turnstile-token]');
                      if (field instanceof HTMLInputElement) field.value = token;
                      const btn = form.querySelector("button[type='submit']");
                      if (btn instanceof HTMLButtonElement) btn.disabled = false;
                    });
                  };
                  window.__turnstileOnExpire = function () {
                    document.querySelectorAll('[data-contact-form]').forEach((form) => {
                      const field = form.querySelector('[data-turnstile-token]');
                      if (field instanceof HTMLInputElement) field.value = '';
                      const btn = form.querySelector("button[type='submit']");
                      if (btn instanceof HTMLButtonElement) btn.disabled = true;
                    });
                  };
                  window.__turnstileOnError = function () {
                    document.querySelectorAll('[data-contact-form]').forEach((form) => {
                      const status = form.querySelector('[data-contact-status]');
                      if (status instanceof HTMLElement) {
                        status.textContent =
                          'Security check failed to load. Refresh the page or email sales@antbar.com directly.';
                        status.hidden = false;
                        status.dataset.ok = 'false';
                      }
                    });
                  };
                </script>
                <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer />
                <div class="contact-form__field contact-form__field--turnstile" data-turnstile-wrap>
                  <div
                    class="cf-turnstile"
                    data-sitekey={turnstileSiteKey}
                    data-callback="__turnstileOnSuccess"
                    data-expired-callback="__turnstileOnExpire"
                    data-error-callback="__turnstileOnError"
                    data-refresh-expired="auto"
                    data-retry="auto"
                    data-theme="light"
                  />
                </div>
                <input type="hidden" name="cf-turnstile-response" data-turnstile-token value="" />
              </>
            )
          }

          <input type="hidden" name="source_path" value={Astro.url.pathname} />

          <div class="contact-form__actions">
            <button
              class="contact-form__submit"
              type="submit"
              disabled={turnstileSiteKey ? true : undefined}
            >
              Submit
            </button>
          </div>
          <p class="contact-form__status" data-contact-status hidden></p>
        </div>
      </form>
    </section>
  </main>
</ContactLayout>

<script>
  const isWorkersDev = window.location.hostname.endsWith('.workers.dev');

  const getTurnstileToken = (form: HTMLFormElement) => {
    const field = form.querySelector('[data-turnstile-token]');
    if (field instanceof HTMLInputElement && field.value) {
      return field.value;
    }
    const value = new FormData(form).get('cf-turnstile-response');
    return typeof value === 'string' && value.length > 0 ? value : '';
  };

  const resetTurnstile = (form: HTMLFormElement) => {
    const widget = form.querySelector('.cf-turnstile');
    const field = form.querySelector('[data-turnstile-token]');
    if (field instanceof HTMLInputElement) field.value = '';
    if (typeof window.turnstile?.reset === 'function' && widget instanceof HTMLElement) {
      window.turnstile.reset(widget);
    }
  };

  if (isWorkersDev) {
    document.querySelectorAll('[data-turnstile-wrap]').forEach((element) => {
      element.setAttribute('hidden', '');
    });
    document.querySelectorAll("[data-contact-form] button[type='submit']").forEach((button) => {
      if (button instanceof HTMLButtonElement) button.disabled = false;
    });
  }

  document.querySelectorAll('[data-contact-form]').forEach((form) => {
    if (!(form instanceof HTMLFormElement)) return;

    const statusEl = form.querySelector('[data-contact-status]');
    const submitBtn = form.querySelector("[type='submit']");
    const requiresTurnstile = !isWorkersDev && Boolean(form.querySelector('.cf-turnstile'));

    const setStatus = (msg: string, ok: boolean) => {
      if (!(statusEl instanceof HTMLElement)) return;
      statusEl.textContent = msg;
      statusEl.hidden = false;
      statusEl.dataset.ok = ok ? 'true' : 'false';
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = true;
      setStatus('Sending...', true);

      try {
        if (requiresTurnstile && !getTurnstileToken(form)) {
          throw new Error('Please complete the security check, then send the message again.');
        }

        const resp = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const contentType = resp.headers.get('content-type') || '';
        const result = contentType.includes('application/json') ? await resp.json() : null;

        if (!resp.ok || !result?.ok) {
          const fallback =
            resp.status === 405
              ? 'The contact form endpoint is not available on this deployment. Please email sales@antbar.com directly.'
              : 'Failed to send. Please try again.';
          throw new Error(result?.error || fallback);
        }

        setStatus('Thank you! Your message has been sent.', true);
        form.reset();
        resetTurnstile(form);
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Network error. Please check your connection.';
        setStatus(message, false);
        if (requiresTurnstile) resetTurnstile(form);
      } finally {
        if (submitBtn instanceof HTMLButtonElement) {
          submitBtn.disabled = requiresTurnstile && !getTurnstileToken(form);
        }
      }
    });
  });
</script>
