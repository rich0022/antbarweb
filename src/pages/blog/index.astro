---
import { getCollection } from 'astro:content';
import ArchiveFeaturedPost from '../../components/archive/ArchiveFeaturedPost.astro';
import ArchivePageHero from '../../components/archive/ArchivePageHero.astro';
import ArchivePostGrid from '../../components/archive/ArchivePostGrid.astro';
import ArchiveLayout from '../../layouts/ArchiveLayout.astro';
import { BLOG_ARCHIVE_PAGE } from '../../data/archive-pages';
import { listArchivePosts, resolveFeaturedArchivePost } from '../../lib/archive-posts';

const allBlog = await getCollection('blog');
const blogIndex = allBlog.find((entry) => entry.id === 'index' || entry.data.slug === 'blog');
const pageConfig = BLOG_ARCHIVE_PAGE;

const allCards = await listArchivePosts('blog', allBlog);
const featured = await resolveFeaturedArchivePost('blog', pageConfig.featuredSlug, allBlog);
const gridCards = allCards.filter((card) => !card.href.endsWith(`/${pageConfig.featuredSlug}/`));
---

<ArchiveLayout
  title={blogIndex?.data.title ?? 'ANTBAR Blog'}
  description={blogIndex?.data.description ?? ''}
  canonical="/blog/"
>
  <main id="content" class="site-main archive-page">
    <ArchivePageHero {...pageConfig.hero} />
    {featured && <ArchiveFeaturedPost {...featured} />}
    <ArchivePostGrid cards={gridCards} />
  </main>
</ArchiveLayout>
