---
import { getCollection, getEntry, render } from 'astro:content';
import ArticlePage from '../../components/article/ArticlePage.astro';
import ArticleShellRuntime from '../../components/article/ArticleShellRuntime.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { contentEntrySlug } from '../../lib/content-entry';
import {
  BLOG_FEATURED_ITEMS,
  BLOG_HOT_SALE_PRODUCTS,
  BLOG_LATEST_ITEMS,
  BLOG_RELATED_ITEMS,
  extractTocItems,
  readMarkdownBody,
  readMirrorArticleMeta,
  readMirrorPublishedLabel,
} from '../../lib/article-page';

export async function getStaticPaths() {
  const contentPosts = await getCollection('blog');

  return contentPosts
    .filter((entry) => entry.id !== 'index' && entry.data.slug !== 'blog')
    .map((entry) => ({
      params: { slug: contentEntrySlug(entry.id, 'blog') },
      props: { entryId: entry.id },
    }));
}

const props = Astro.props as {
  entryId: string;
};

const entry = await getEntry('blog', props.entryId);
if (!entry) {
  throw new Error(`Missing blog entry for ${props.entryId}`);
}
const { Content } = await render(entry);
const slug = contentEntrySlug(entry.id, 'blog');
const [markdownBody, publishedLabel, articleMeta] = await Promise.all([
  readMarkdownBody('blog', props.entryId),
  readMirrorPublishedLabel(`blog/${slug}`),
  readMirrorArticleMeta(`blog/${slug}`),
]);

const tocItems = extractTocItems(markdownBody);
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description ?? entry.data.excerpt ?? ''}
  mirrorRoute={`blog/${slug}`}
  bodyClass={articleMeta.bodyClass}
>
  <ArticlePage
    title={entry.data.title}
    sectionLabel="Blog"
    currentPostId={articleMeta.postId}
    publishedLabel={publishedLabel}
    tocItems={tocItems}
    latestItems={BLOG_LATEST_ITEMS}
    relatedTitle="Related Blogs"
    relatedItems={BLOG_RELATED_ITEMS}
    featuredItems={BLOG_FEATURED_ITEMS}
    hotProducts={BLOG_HOT_SALE_PRODUCTS}
  >
    <Content />
  </ArticlePage>
  <ArticleShellRuntime
    postId={articleMeta.postId ?? 4603}
    title={entry.data.title}
    excerpt={entry.data.excerpt ?? entry.data.description ?? ''}
    featuredImage={entry.data.heroImage ?? entry.data.featuredImage ?? '/wp-content/uploads/2024/05/LOGO.png'}
  />
</ArticleLayout>
