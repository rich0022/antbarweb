---
import { getCollection, getEntry, render } from 'astro:content';
import ArticlePage from '../../components/article/ArticlePage.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { contentEntrySlug } from '../../lib/content-entry';
import {
  BLOG_FEATURED_ITEMS,
  BLOG_HOT_SALE_PRODUCTS,
  BLOG_LATEST_ITEMS,
  BLOG_RELATED_ITEMS,
  extractTocItems,
  formatPublishedLabel,
  readMarkdownBody,
} from '../../lib/article-page';

export async function getStaticPaths() {
  const contentPosts = await getCollection('blog');

  return contentPosts
    .filter((entry) => entry.id !== 'index' && entry.data.slug !== 'blog')
    .map((entry) => ({
      params: { slug: contentEntrySlug(entry.id, 'blog') },
      props: { slug: contentEntrySlug(entry.id, 'blog'), entryId: entry.id },
    }));
}

const props = Astro.props as {
  slug: string;
  entryId: string;
};

const entry = await getEntry('blog', props.entryId);
if (!entry) {
  throw new Error(`Missing blog entry for ${props.entryId}`);
}

const title = entry.data.seo?.title ?? entry.data.title;
const description = entry.data.seo?.description ?? entry.data.description ?? entry.data.excerpt ?? '';
const canonicalOverride = entry.data.seo?.canonical;
const publishedLabel = formatPublishedLabel(entry.data.publishedAt);

const [{ Content }, markdownBody] = await Promise.all([
  render(entry),
  readMarkdownBody('blog', props.entryId),
]);

const tocItems = extractTocItems(markdownBody);
---

<ArticleLayout
  title={title}
  description={description}
  bodyClass="article-page-body blog-article-body"
  canonical={canonicalOverride ?? `/blog/${props.slug}/`}
  image={entry.data.heroImage}
  article={{
    publishedAt: entry.data.publishedAt,
    updatedAt: entry.data.updatedAt,
    author: entry.data.author,
    tags: entry.data.tags,
  }}
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'Blog', item: '/blog/' },
    { name: entry.data.title, item: `/blog/${props.slug}/` },
  ]}
  jsonArticle={{
    headline: entry.data.title,
    description: description,
    image: entry.data.heroImage,
    datePublished: entry.data.publishedAt,
    dateModified: entry.data.updatedAt,
    author: entry.data.author,
    publisher: 'ANTBAR',
  }}
>
  <ArticlePage
    title={title}
    sectionLabel="Blog"
    publishedLabel={publishedLabel}
    tocItems={tocItems}
    latestItems={BLOG_LATEST_ITEMS}
    relatedTitle="Related Blogs"
    relatedItems={BLOG_RELATED_ITEMS}
    featuredItems={BLOG_FEATURED_ITEMS}
    hotProducts={BLOG_HOT_SALE_PRODUCTS}
  >
    <Content />
  </ArticlePage>
</ArticleLayout>
