---
import { getCollection } from 'astro:content';
import LegalLayout from '../layouts/LegalLayout.astro';

const pages = await getCollection('pages');
const entry = pages.find((p) => p.id === 'privacy-policy');
---

<LegalLayout
  title={entry?.data.title ?? 'Privacy Policy | ANTBAR'}
  description={entry?.data.description ?? ''}
>
  <main id="content" class="site-main legal-page">
    <div class="legal-page__inner">
      <h1 class="legal-page__title">Privacy Policy</h1>
      <p class="legal-page__updated">Last updated: June 11, 2026</p>

      <div class="legal-page__content">
        <p>
          ANTBAR ("we", "us", or "our") operates antbar.com. This Privacy Policy explains what
          information we collect when you visit our website, verify your age, search for content,
          or submit a contact inquiry, and how we use that information.
        </p>

        <h2>Information we collect</h2>
        <ul>
          <li>
            <strong>Contact form submissions:</strong> name, email address, message content, and
            anti-spam verification data when you use our contact form.
          </li>
          <li>
            <strong>Technical data:</strong> browser type, device information, IP address, and
            standard server logs collected by our hosting provider for security and performance.
          </li>
          <li>
            <strong>Local storage:</strong> a simple age-verification flag stored in your browser
            so we do not repeatedly show the age gate during the same visit session.
          </li>
        </ul>

        <h2>How we use information</h2>
        <p>We use the information above to:</p>
        <ul>
          <li>respond to wholesale and business inquiries;</li>
          <li>protect the website from spam and abuse;</li>
          <li>maintain website security, reliability, and performance;</li>
          <li>comply with legal obligations related to age-restricted products.</li>
        </ul>

        <h2>Age-restricted content</h2>
        <p>
          Our website contains information about nicotine-containing products intended for adults
          aged 21 and over. By confirming your age, you represent that you meet the legal age
          requirement in your jurisdiction.
        </p>

        <h2>Cookies and similar technologies</h2>
        <p>
          We use browser storage and security tools that may set cookies or similar identifiers.
          These are used for age verification, form protection, and site operation. You can control
          cookies through your browser settings, although some features may not work correctly if
          cookies are disabled.
        </p>

        <h2>Data retention</h2>
        <p>
          Contact inquiries are retained only as long as needed to respond to your request, maintain
          business records, or meet legal requirements.
        </p>

        <h2>Your choices</h2>
        <p>
          You may request access to, correction of, or deletion of contact information you have
          submitted to us by emailing
          <a href="mailto:info@antbar.com">info@antbar.com</a>.
        </p>

        <h2>Changes to this policy</h2>
        <p>
          We may update this Privacy Policy from time to time. The "Last updated" date at the top of
          this page will reflect the most recent revision.
        </p>

        <h2>Contact us</h2>
        <p>
          If you have questions about this Privacy Policy, please contact us at
          <a href="mailto:info@antbar.com">info@antbar.com</a> or through our
          <a href="/contact/">contact page</a>.
        </p>
      </div>
    </div>
  </main>
</LegalLayout>
