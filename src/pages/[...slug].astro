---
import { readdir, readFile } from 'node:fs/promises';
import path from 'node:path';
import { collectMirroredPages } from '../lib/mirror-pages.js';

export async function getStaticPaths() {
  const ROOT = path.resolve(process.cwd());
  const PUBLIC_DIR = path.join(ROOT, 'public');
  const pages = await collectMirroredPages(PUBLIC_DIR);
  return pages.map((page) => ({
    params: { slug: page.route },
    props: page,
  }));
}

const { filePath } = Astro.props as { filePath: string };
const rawHtml = await readFile(filePath, 'utf8');
const mirroredDocument = rawHtml.replace(/^<!doctype html>\s*/i, '');
---

<!DOCTYPE html>
<Fragment set:html={mirroredDocument} />
