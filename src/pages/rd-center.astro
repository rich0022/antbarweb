---
import { getCollection } from 'astro:content';
import SiteShellLayout from '../layouts/SiteShellLayout.astro';
import { ANIMATION_INLINE_CSS } from '../data/site-assets';
import '../styles/rd-center.css';

const pages = await getCollection('pages');
const entry = pages.find((page) => page.id === 'rd-center');
const bodyClass =
  'rd-center-body';

const counters = [
  { title: 'SOFTWARE COPYRIGHT', value: '6' },
  { title: 'INVENTION PATENT', value: '60' },
  { title: 'PCT', value: '40' },
  { title: 'PRODUCT APPEARANCE PATENT', value: '79' },
  { title: 'UTILITY MODEL PATENT', value: '259' },
] as const;

const universities = [
  {
    img: '/wp-content/uploads/2024/04/RD-Center-1.avif',
    bg: '/wp-content/uploads/2024/04/第1个.avif',
    w: 344,
    h: 266,
    name: 'Huazhong University of Science and Technology',
  },
  {
    img: '/wp-content/uploads/2024/04/RD-Center-2.avif',
    bg: '/wp-content/uploads/2024/04/第2个.avif',
    w: 270,
    h: 270,
    name: 'Wuhan Textile University',
  },
  {
    img: '/wp-content/uploads/2024/04/RD-Center-3.avif',
    bg: '/wp-content/uploads/2024/04/第3个.avif',
    w: 272,
    h: 271,
    name: 'Wuhan Institute of Advanced Technology Chinese Academy of Science',
  },
  {
    img: '/wp-content/uploads/2024/04/RD-Center-4.avif',
    bg: '/wp-content/uploads/2024/04/第4个.avif',
    w: 271,
    h: 271,
    name: 'China University of Geosciences',
  },
] as const;

const patents = [
  { src: '/wp-content/uploads/2024/04/1.avif', w: 482, h: 636 },
  { src: '/wp-content/uploads/2024/04/2.avif', w: 482, h: 636 },
  { src: '/wp-content/uploads/2024/04/3.avif', w: 482, h: 636 },
  { src: '/wp-content/uploads/2024/04/4.avif', w: 482, h: 636 },
] as const;
---

<SiteShellLayout
  title={entry?.data.title ?? 'R&D Center'}
  description={entry?.data.description ?? ''}
  bodyClass={bodyClass}
  canonical="/rd-center/"
  breadcrumbs={[{ name: 'Home', item: '/' }, { name: 'R&D Center', item: '/rd-center/' }]}
  inlineStyles={[ANIMATION_INLINE_CSS]}
>
  <main id="content" class="site-main rd-center-page">
    <section class="rd-hero scroll-bn" aria-label="R&D Center hero">
      <picture class="rd-hero__picture">
        <source
          media="(max-width: 767px)"
          srcset="/wp-content/uploads/2024/05/RD-Center.avif 1170w, /wp-content/uploads/2024/05/RD-Center-182x300.webp 182w, /wp-content/uploads/2024/05/RD-Center-620x1024.webp 620w, /wp-content/uploads/2024/05/RD-Center-768x1268.avif 768w, /wp-content/uploads/2024/05/RD-Center-931x1536.avif 931w"
          sizes="(max-width: 1170px) 100vw, 1170px"
        />
        <img
          loading="eager"
          decoding="async"
          width="2560"
          height="1248"
          src="/wp-content/uploads/2024/04/RD-Center-1-scaled.avif"
          srcset="/wp-content/uploads/2024/04/RD-Center-1-scaled.avif 2560w, /wp-content/uploads/2024/04/RD-Center-1-300x146.webp 300w, /wp-content/uploads/2024/04/RD-Center-1-1024x499.webp 1024w, /wp-content/uploads/2024/04/RD-Center-1-768x374.webp 768w, /wp-content/uploads/2024/04/RD-Center-1-1536x749.avif 1536w, /wp-content/uploads/2024/04/RD-Center-1-2048x998.avif 2048w"
          sizes="(max-width: 2560px) 100vw, 2560px"
          alt=""
        />
      </picture>
    </section>

    <section class="rd-intro" aria-labelledby="rd-center-title">
      <div class="rd-intro__inner">
        <div class="rd-intro__content">
          <img
            class="rd-intro__image scroll-reveal"
            data-animate="fadeInUp"
            loading="lazy"
            decoding="async"
            width="1809"
            height="1175"
            src="/wp-content/uploads/2024/04/RD-Center-2.avif"
            srcset="/wp-content/uploads/2024/04/RD-Center-2.avif 1809w, /wp-content/uploads/2024/04/RD-Center-2-300x195.webp 300w, /wp-content/uploads/2024/04/RD-Center-2-1024x665.avif 1024w, /wp-content/uploads/2024/04/RD-Center-2-768x499.webp 768w, /wp-content/uploads/2024/04/RD-Center-2-1536x998.avif 1536w"
            sizes="(max-width: 1809px) 100vw, 1809px"
            alt=""
          />
          <p class="rd-intro__text scroll-reveal" data-animate="fadeInUp">
            Driven by market-oriented and technological innovation, Antbar spares no expense and effort in research and development. Based on independent research and development, Antbar have established a professional R&D team led by senior engineers in the industry and introduced advanced scientific equipment. The team has a keen mind on the vaping industry and new trend, and keeps on rolling out more optimal solutions by integrating technology, marketing and production, committed to creating products with more stable performance. Antbar has cooperated with several renowned universities on new materials and technical to solve some tricky problems in this field. Antbar strives to become an industry-leading atomizer technology corporation that drives the innovation of electronic atomizer.
          </p>
        </div>
        <div class="rd-intro__heading">
          <h1 id="rd-center-title" class="scroll-reveal" data-animate="fadeInUp">R&amp;D<br>Center</h1>
          <img
            class="scroll-reveal"
            data-animate="fadeInUp"
            loading="lazy"
            decoding="async"
            width="96"
            height="32"
            src="/wp-content/uploads/2024/04/图标-2.webp"
            alt=""
          />
        </div>
      </div>
    </section>

    <section class="rd-universities" aria-label="R&D university cooperation">
      <div class="rd-universities__grid">
        {universities.map((university) => (
          <article class="rd-university-card" style={`--rd-card-bg: url("${university.bg}")`}>
            <img loading="lazy" decoding="async" width={university.w} height={university.h} src={university.img} alt={university.name} />
            <p>{university.name}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="rd-property" aria-labelledby="rd-property-title">
      <div class="rd-property__intro">
        <div class="rd-property__visual">
          <video
            class="rd-property__earth"
            width="1016"
            height="989"
            poster="/wp-content/uploads/2024/04/地球-poster.webp"
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            aria-hidden="true"
          >
            <source src="/wp-content/uploads/2024/04/地球.webm" type="video/webm" />
            <source src="/wp-content/uploads/2024/04/地球.mp4" type="video/mp4" />
          </video>
        </div>
        <div class="rd-property__heading">
          <h2 id="rd-property-title" class="scroll-reveal" data-animate="fadeInUp">Intellectual<br />Property</h2>
          <img
            class="scroll-reveal"
            data-animate="fadeInUp"
            loading="lazy"
            decoding="async"
            width="96"
            height="32"
            src="/wp-content/uploads/2024/04/图标-2.webp"
            alt=""
          />
        </div>
        <p class="rd-property__text scroll-reveal" data-animate="fadeInUp">
          Advocating scientific and technological innovation and market-oriented, Antbar produces some products that are widely sold in dozens of countries and regions around the world. With its excellent technical advantage and market competitiveness, Antbar has won recognition and praise from a large number of enterprises, distributors, and consumers at home and abroad.
        </p>
      </div>

      <div class="rd-counters" aria-label="Patent statistics">
        {counters.map((counter) => (
          <div class="rd-counter scroll-reveal" data-animate="fadeInUp">
            <p>{counter.title}</p>
            <strong data-count={counter.value}>0</strong>
          </div>
        ))}
      </div>

      <div class="rd-patents">
        {patents.map((patent) => (
          <figure class="rd-patent scroll-reveal" data-animate="fadeInUp">
            <img loading="lazy" decoding="async" width={patent.w} height={patent.h} src={patent.src} alt="ANTBAR patent certificate" />
          </figure>
        ))}
      </div>
    </section>
  </main>
</SiteShellLayout>

<script is:inline>
  (() => {
    const counters = document.querySelectorAll('.rd-counter strong[data-count]');
    if (!counters.length) return;

    const animate = (el) => {
      const target = parseInt(el.getAttribute('data-count'), 10);
      if (isNaN(target)) return;
      const duration = 2000;
      const start = performance.now();

      const tick = (now) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(eased * target);
        if (progress < 1) requestAnimationFrame(tick);
      };

      requestAnimationFrame(tick);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animate(entry.target);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );

    counters.forEach((el) => observer.observe(el));
  })();
</script>
