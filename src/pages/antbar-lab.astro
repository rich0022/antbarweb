---
import { getCollection } from 'astro:content';
import SiteShellLayout from '../layouts/SiteShellLayout.astro';
import { ANTBAR_LAB_CERTS, ANTBAR_LAB_HERO, ANTBAR_LAB_INTRO } from '../data/about-subpages';
import { ANIMATION_INLINE_CSS } from '../data/site-assets';
import '../styles/antbar-lab.css';

const pages = await getCollection('pages');
const entry = pages.find((page) => page.id === 'antbar-lab');
const hero = ANTBAR_LAB_HERO;
const intro = ANTBAR_LAB_INTRO;
const certs = ANTBAR_LAB_CERTS;
const bodyClass =
  'antbar-lab-body';
---

<SiteShellLayout
  title={entry?.data.title ?? 'Antbar Lab'}
  description={entry?.data.description ?? ''}
  bodyClass={bodyClass}
  inlineStyles={[ANIMATION_INLINE_CSS]}
>
  <main id="content" class="site-main lab-page">
    <section class="lab-hero scroll-bn" aria-label="Antbar Lab hero">
      <picture class="lab-hero__picture">
        <source media="(max-width: 767px)" srcset={hero.mobileImage.srcset} sizes={hero.mobileImage.sizes} />
        <img
          loading="eager"
          decoding="async"
          width={hero.desktopImage.width}
          height={hero.desktopImage.height}
          src={hero.desktopImage.src}
          srcset={hero.desktopImage.srcset}
          sizes={hero.desktopImage.sizes}
          alt=""
        />
      </picture>
    </section>

    <section class="lab-intro" aria-labelledby="lab-title">
      <div class="lab-intro__grid">
        <div class="lab-intro__left scroll-reveal" data-animate="fadeInLeft">
          <div class="lab-intro__kicker">
            <div>
              <p>TO EXPLORE</p>
              <p><strong>TO EXPERIENCE</strong></p>
            </div>
            <img loading="lazy" decoding="async" width={intro.iconWidth} height={intro.iconHeight} src="/wp-content/uploads/2024/04/图标.png" alt="" />
          </div>
          <img
            class="lab-intro__wide-image"
            loading="lazy"
            decoding="async"
            width={intro.leftImage.width}
            height={intro.leftImage.height}
            src={intro.leftImage.src}
            srcset={intro.leftImage.srcset}
            sizes={intro.leftImage.sizes}
            alt=""
          />
        </div>
        <div class="lab-intro__right scroll-reveal" data-animate="fadeInRight">
          <img
            loading="lazy"
            decoding="async"
            width={intro.rightImage.width}
            height={intro.rightImage.height}
            src={intro.rightImage.src}
            srcset={intro.rightImage.srcset}
            sizes={intro.rightImage.sizes}
            alt=""
          />
          <p>{intro.rightText}</p>
        </div>
      </div>

      <div class="lab-intro__summary">
        <h1 id="lab-title" class="scroll-reveal" data-animate="fadeInUp">{intro.bottomHeading}</h1>
        <p class="scroll-reveal" data-animate="fadeInUp">{intro.bottomText}</p>
      </div>
    </section>

    <section class="lab-certs" aria-labelledby="lab-certs-title">
      <div class="lab-certs__intro">
        <h2 id="lab-certs-title" class="scroll-reveal" data-animate="fadeInUp" set:html={certs.heading} />
        <p>{certs.text}</p>
      </div>
      <div class="lab-certs__grid scroll-reveal" data-animate="fadeInUp">
        {certs.certs.map((cert) => (
          <figure class="lab-cert">
            <img
              loading="lazy"
              decoding="async"
              width={cert.width}
              height={cert.height}
              src={cert.src}
              srcset={cert.srcset}
              sizes={`(max-width: ${cert.width}px) 100vw, ${cert.width}px`}
              alt=""
            />
          </figure>
        ))}
      </div>
    </section>
  </main>
</SiteShellLayout>
