---
import { getCollection } from 'astro:content';
import SiteShellLayout from '../layouts/SiteShellLayout.astro';
import {
  BRAND_STORY_FINAL,
  BRAND_STORY_GALLERY_IMAGES,
  BRAND_STORY_HERO,
  BRAND_STORY_HERO_SECTION_WIDGETS,
} from '../data/about-subpages';
import { ANIMATION_INLINE_CSS } from '../data/site-assets';
import '../styles/brand-story.css';

const pages = await getCollection('pages');
const entry = pages.find((page) => page.id === 'brand-story');
const hero = BRAND_STORY_HERO;
const intro = BRAND_STORY_HERO_SECTION_WIDGETS;
const final = BRAND_STORY_FINAL;
const bodyClass =
  'brand-story-body';
---

<SiteShellLayout
  title={entry?.data.title ?? 'Brand Story'}
  description={entry?.data.description ?? ''}
  bodyClass={bodyClass}
  canonical="/brand-story/"
  breadcrumbs={[{ name: 'Home', item: '/' }, { name: 'Brand Story', item: '/brand-story/' }]}
  inlineStyles={[ANIMATION_INLINE_CSS]}
>
  <main id="content" class="site-main brand-story-page">
    <section class="brand-story-hero scroll-bn" aria-label="Brand story hero">
      <picture class="brand-story-hero__picture">
        <source media="(max-width: 767px)" srcset={hero.mobileImage.srcset} sizes={hero.mobileImage.sizes} />
        <img
          loading="eager"
          decoding="async"
          width={hero.desktopImage.width}
          height={hero.desktopImage.height}
          src={hero.desktopImage.src}
          srcset={hero.desktopImage.srcset}
          sizes={hero.desktopImage.sizes}
          alt=""
        />
      </picture>
      {hero.overlay && (
        <div class="brand-story-hero__overlay">
          <div class="brand-story-hero__copy scroll-reveal" data-animate="fadeInUp">
            <p>{hero.overlay.headings[0]}</p>
            <p><strong>{hero.overlay.headings[1]}</strong></p>
          </div>
        </div>
      )}
    </section>

    <section class="brand-story-intro" aria-labelledby="brand-story-title">
      <div class="brand-story-intro__inner">
        <div class="brand-story-intro__heading scroll-reveal" data-animate="fadeInUp">
          <h1 id="brand-story-title">Brand <span class="brand-story__title-break">story</span></h1>
          <img
            loading="lazy"
            decoding="async"
            width={intro.iconWidth}
            height={intro.iconHeight}
            src={intro.iconSrc}
            alt=""
          />
        </div>
        <div class="brand-story-intro__text scroll-reveal" data-animate="fadeInUp">
          <p set:html={intro.text} />
        </div>
      </div>
    </section>

    <section class="brand-story-gallery" aria-label="Brand story gallery">
      <div class="brand-story-gallery__track">
        {BRAND_STORY_GALLERY_IMAGES.map((image) => (
          <button
            class:list={['brand-story-gallery__item', image.active && 'is-active']}
            type="button"
            data-brand-story-gallery-item
            aria-label="Show brand story image"
          >
            <img
              loading="lazy"
              decoding="async"
              width={image.width}
              height={image.height}
              src={image.src}
              srcset={image.srcset}
              sizes="(max-width: 767px) 90vw, 958px"
              alt=""
            />
          </button>
        ))}
      </div>
    </section>

    <section class="brand-story-final" aria-label="Brand story details">
      <div class="brand-story-final__inner">
        <div class="brand-story-final__image scroll-reveal" data-animate="fadeInUp">
          <img
            loading="lazy"
            decoding="async"
            width={final.image.width}
            height={final.image.height}
            src={final.image.src}
            srcset={final.image.srcset}
            sizes={final.image.sizes}
            alt=""
          />
        </div>
        <div class="brand-story-final__text scroll-reveal" data-animate="fadeInLeft">
          <p>{final.text}</p>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const items = Array.from(document.querySelectorAll('[data-brand-story-gallery-item]'));
      if (!items.length) return;

      const activate = (activeItem) => {
        items.forEach((item) => item.classList.toggle('is-active', item === activeItem));
      };

      items.forEach((item) => {
        item.addEventListener('mouseenter', () => activate(item));
        item.addEventListener('focus', () => activate(item));
        item.addEventListener('click', () => activate(item));
      });
    })();
  </script>
</SiteShellLayout>
