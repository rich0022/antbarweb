---
import { getCollection } from 'astro:content';
import ContentBody from '../../components/ContentBody.astro';
import ProductLayout from '../../layouts/ProductLayout.astro';
import { contentEntryFileName } from '../../lib/content-entry';
import { readContentBody } from '../../lib/content-body';
import {
  collectPodSysMirrorRoutes,
  readMirrorBodyHtml,
  resolveMirrorRoute,
} from '../../lib/mirror-assets';
import { POD_SYS_DISPOSABLE_ALIASES } from '../../lib/route-aliases';
import { readFile } from 'node:fs/promises';
import path from 'node:path';

export async function getStaticPaths() {
  const entries = await getCollection('products');
  const mirrorRoutes = await collectPodSysMirrorRoutes();
  const paths = new Map<string, Record<string, unknown>>();

  for (const entry of entries) {
    if (!entry.id.startsWith('pod-sys/')) continue;
    if (entry.id === 'pod-sys' || entry.id === 'pod-sys/index') continue;
    const urlSlug = entry.id.replace(/^pod-sys\//, '');
    paths.set(urlSlug, { mode: 'content' as const, entry });
  }

  for (const [urlSlug, mirrorRoute] of mirrorRoutes) {
    if (urlSlug === 'index') continue;
    if (!paths.has(urlSlug)) {
      paths.set(urlSlug, { mode: 'mirror' as const, slug: urlSlug, mirrorRoute });
    }
  }

  for (const [urlSlug, contentPath] of Object.entries(POD_SYS_DISPOSABLE_ALIASES)) {
    if (paths.has(urlSlug)) continue;
    const entry = entries.find((item) => item.id === contentPath);
    if (entry) {
      paths.set(urlSlug, { mode: 'content' as const, entry, mirrorRoute: contentPath });
    }
  }

  return [...paths.entries()].map(([slug, routeProps]) => ({
    params: { slug },
    props: { slug, ...routeProps },
  }));
}

const props = Astro.props as {
  slug: string;
  mode: 'content' | 'mirror';
  mirrorRoute?: string;
  entry?: { id: string; data: { title: string; description?: string } };
};

let title = 'ANTBAR Pod System';
let description = '';
let bodyHtml = '';
let mirrorRoute = props.mirrorRoute ?? `pod-sys/${props.slug}`;

if (props.mode === 'content' && props.entry) {
  title = props.entry.data.title;
  description = props.entry.data.description ?? '';
  const fileName = contentEntryFileName(props.entry.id, 'products');
  bodyHtml = await readContentBody('products', fileName);
  mirrorRoute = resolveMirrorRoute('products', fileName);
} else {
  const route = props.mirrorRoute ?? `pod-sys/${props.slug}`;
  const htmlPath = path.join(process.cwd(), 'mirror', route, 'index.html');
  const raw = await readFile(htmlPath, 'utf8');
  title = raw.match(/<title[^>]*>([\s\S]*?)<\/title>/i)?.[1]?.trim() ?? title;
  description =
    raw.match(/<meta[^>]*name=["']description["'][^>]*content=["']([^"']*)["']/i)?.[1] ?? '';
  bodyHtml = await readMirrorBodyHtml(route);
  mirrorRoute = route;
}
---

<ProductLayout title={title} description={description} mirrorRoute={mirrorRoute}>
  <ContentBody html={bodyHtml} />
</ProductLayout>
