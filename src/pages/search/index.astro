---
import SiteShellLayout from '../../layouts/SiteShellLayout.astro';
import '../../styles/search.css';

const labels = {
  title: 'Search | ANTBAR',
  description: 'Search products, blog posts, and pages on the ANTBAR website.',
  heading: 'Search',
  placeholder: 'Search products, blog, pages...',
  button: 'Search',
  initialHint: 'Type a keyword to search the site.',
  searching: 'Searching...',
  noResults: 'No results found.',
  notReady: 'Search index is not ready yet. Please try again in a moment.',
  found: 'Found',
  products: 'Products',
  blog: 'Blog',
  pages: 'Pages',
  all: 'All',
  loadMore: 'Load more',
  remaining: 'remaining',
};
---

<SiteShellLayout title={labels.title} description={labels.description} noindex bodyClass="search-page-body">
  <main id="content" class="site-main search-page">
    <div class="search-page__inner" data-search-labels={JSON.stringify(labels)}>
      <header class="search-page__hero">
        <h1 class="search-page__title">{labels.heading}</h1>
        <p class="search-page__lede">Find products, blog articles, and site pages across ANTBAR.</p>
        <form class="search-page__form" id="search-page-form" role="search">
          <label class="search-page__field">
            <span class="search-page__field-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20">
                <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"></circle>
                <path d="m16.5 16.5 4 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
              </svg>
            </span>
            <input
              id="search-page-input"
              type="search"
              placeholder={labels.placeholder}
              autocomplete="off"
              aria-label={labels.heading}
            />
          </label>
          <button id="search-page-button" class="search-page__submit" type="submit">{labels.button}</button>
        </form>
      </header>

      <div class="search-page__body">
        <p id="search-page-hint" class="search-page__hint">{labels.initialHint}</p>

        <div class="search-page__filters" id="search-page-filters" hidden>
          <button type="button" class="search-page__filter is-active" data-filter="all" data-label={labels.all}>
            {labels.all}
            <span class="search-page__filter-count" data-filter-count="all"></span>
          </button>
          <button type="button" class="search-page__filter" data-filter="product" data-label={labels.products}>
            {labels.products}
            <span class="search-page__filter-count" data-filter-count="product"></span>
          </button>
          <button type="button" class="search-page__filter" data-filter="blog" data-label={labels.blog}>
            {labels.blog}
            <span class="search-page__filter-count" data-filter-count="blog"></span>
          </button>
          <button type="button" class="search-page__filter" data-filter="page" data-label={labels.pages}>
            {labels.pages}
            <span class="search-page__filter-count" data-filter-count="page"></span>
          </button>
        </div>

        <div id="search-page-output" class="search-page__output"></div>
        <button type="button" id="search-page-more" class="search-page__more" hidden>{labels.loadMore}</button>
      </div>
    </div>
  </main>
</SiteShellLayout>

<script>
  import {
    SEARCH_PAGE_SIZE,
    escapeHtml,
    filterByType,
    formatResultPath,
    groupByType,
    loadPagefind,
    enrichResults,
    truncateExcerpt,
    type EnrichedSearchResult,
    type SearchResultType,
  } from '@/lib/pagefind-search';

  const form = document.getElementById('search-page-form');
  const input = document.getElementById('search-page-input');
  const button = document.getElementById('search-page-button');
  const hint = document.getElementById('search-page-hint');
  const filters = document.getElementById('search-page-filters');
  const output = document.getElementById('search-page-output');
  const moreButton = document.getElementById('search-page-more');
  const labelSource = document.querySelector('[data-search-labels]');
  const labels = labelSource instanceof HTMLElement
    ? JSON.parse(labelSource.dataset.searchLabels || '{}')
    : {};
  const typeLabels = {
    product: labels.products || 'Products',
    blog: labels.blog || 'Blog',
    page: labels.pages || 'Pages',
  };

  let allResults: EnrichedSearchResult[] = [];
  let activeFilter: SearchResultType | 'all' = 'all';
  let visibleCount = SEARCH_PAGE_SIZE;

  const getKeyword = () => new URLSearchParams(window.location.search).get('q')?.trim() || '';

  const setKeyword = (keyword: string) => {
    const url = new URL(window.location.href);
    if (keyword) url.searchParams.set('q', keyword);
    else url.searchParams.delete('q');
    window.history.replaceState({}, '', url.toString());
  };

  const setActiveFilterButton = () => {
    filters?.querySelectorAll('[data-filter]').forEach((node) => {
      if (!(node instanceof HTMLButtonElement)) return;
      node.classList.toggle('is-active', node.dataset.filter === activeFilter);
    });
  };

  const renderCard = (item: EnrichedSearchResult, showBadge = true) => `
    <li class="search-card-item">
      <a class="search-card search-card--${item.resultType}" href="${escapeHtml(item.url)}">
        <div class="search-card-main">
          ${
            showBadge
              ? `<span class="search-badge search-badge--${item.resultType}">${escapeHtml(item.typeLabel)}</span>`
              : ''
          }
          <h3 class="search-card-title">${escapeHtml(item.meta.title || 'Untitled')}</h3>
          <p class="search-card-excerpt">${escapeHtml(truncateExcerpt(item.excerpt, 180, true))}</p>
        </div>
        <div class="search-card-foot">
          <span class="search-card-url">${escapeHtml(formatResultPath(item.url))}</span>
          <span class="search-card-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="16" height="16">
              <path d="M5 12h12M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
        </div>
      </a>
    </li>
  `;

  const renderList = (items: EnrichedSearchResult[]) => `
    <ul class="search-page-results search-page-results--flat">
      ${items.map((item) => renderCard(item, true)).join('')}
    </ul>
  `;

  const renderGrouped = (items: EnrichedSearchResult[]) => {
    const groups = groupByType(items);
    const sections = [
      { key: 'product' as const, title: labels.products || 'Products' },
      { key: 'blog' as const, title: labels.blog || 'Blog' },
      { key: 'page' as const, title: labels.pages || 'Pages' },
    ];

    const html = sections
      .map(({ key, title }) => {
        const groupItems = groups[key];
        if (!groupItems.length) return '';
        return `
          <section class="search-group search-group--${key}">
            <div class="search-group__head">
              <h2 class="search-group__title">${title}</h2>
              <span class="search-group__count">${groupItems.length}</span>
            </div>
            <ul class="search-page-results search-page-results--grouped">
              ${groupItems.map((item) => renderCard(item, false)).join('')}
            </ul>
          </section>
        `;
      })
      .join('');

    return `<div class="search-groups">${html}</div>`;
  };

  const updateFilterCounts = () => {
    const typeCounts = groupByType(allResults);
    filters?.querySelectorAll('[data-filter-count]').forEach((node) => {
      if (!(node instanceof HTMLElement)) return;
      const key = node.dataset.filterCount;
      const count = key === 'all' ? allResults.length : typeCounts[key as SearchResultType]?.length ?? 0;
      node.textContent = String(count);
      node.hidden = !allResults.length;
    });
  };

  const renderEmptyState = (keyword: string) => `
    <div class="search-empty">
      <div class="search-empty__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="40" height="40">
          <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="1.75"></circle>
          <path d="m16.5 16.5 4 4" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
        </svg>
      </div>
      <h2 class="search-empty__title">No results found</h2>
      <p class="search-empty__copy">We could not find anything for <strong>${escapeHtml(keyword)}</strong>. Try another keyword or browse our catalog.</p>
      <a class="search-empty__cta" href="/all-products/">Browse all products</a>
    </div>
  `;

  const updateMoreButton = (filteredCount: number) => {
    if (!(moreButton instanceof HTMLButtonElement)) return;
    const hasMore = filteredCount > visibleCount;
    moreButton.hidden = !hasMore;
    if (hasMore) {
      moreButton.textContent = `${labels.loadMore || 'Load more'} (${filteredCount - visibleCount} ${labels.remaining || 'remaining'})`;
    }
  };

  const render = () => {
    if (!output || !hint) return;

    const filtered = filterByType(allResults, activeFilter);
    const visible = filtered.slice(0, visibleCount);

    if (!allResults.length) {
      const keyword = getKeyword();
      output.innerHTML = keyword ? renderEmptyState(keyword) : '';
      hint.textContent = keyword
        ? labels.noResults || 'No results found.'
        : labels.initialHint || 'Type a keyword to search the site.';
      hint.classList.toggle('search-page__hint--muted', !keyword);
      if (filters) filters.hidden = true;
      updateFilterCounts();
      updateMoreButton(0);
      return;
    }

    const typeCounts = groupByType(allResults);
    hint.classList.remove('search-page__hint--muted');
    hint.innerHTML = `
      <span class="search-page__stat"><strong>${filtered.length}</strong> result${filtered.length === 1 ? '' : 's'}</span>
      <span class="search-page__stat">${typeCounts.product.length} ${labels.products || 'products'}</span>
      <span class="search-page__stat">${typeCounts.blog.length} ${labels.blog || 'blog'}</span>
      <span class="search-page__stat">${typeCounts.page.length} ${labels.pages || 'pages'}</span>
    `;
    updateFilterCounts();

    output.innerHTML = activeFilter === 'all' ? renderGrouped(visible) : renderList(visible);
    if (filters) filters.hidden = false;
    updateMoreButton(filtered.length);
  };

  const runSearch = async () => {
    if (!(input instanceof HTMLInputElement) || !hint) return;

    const keyword = input.value.trim();
    setKeyword(keyword);
    visibleCount = SEARCH_PAGE_SIZE;

    if (!keyword) {
      allResults = [];
      activeFilter = 'all';
      setActiveFilterButton();
      render();
      return;
    }

    hint.textContent = labels.searching || 'Searching...';
    hint.classList.add('search-page__hint--muted');
    if (output) output.innerHTML = '<div class="search-page__loading" aria-hidden="true"></div>';

    const pf = await loadPagefind(24);
    if (!pf) {
      hint.textContent = labels.notReady || 'Search index is not ready yet. Please try again in a moment.';
      return;
    }

    const response = await pf.search(keyword);
    const data = await Promise.all(response.results.map((item) => item.data()));
    allResults = enrichResults(data, typeLabels);
    render();
  };

  filters?.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLButtonElement)) return;
    const next = target.dataset.filter;
    if (!next || (next !== 'all' && next !== 'product' && next !== 'blog' && next !== 'page')) return;

    activeFilter = next;
    visibleCount = SEARCH_PAGE_SIZE;
    setActiveFilterButton();
    render();
  });

  moreButton?.addEventListener('click', () => {
    visibleCount += SEARCH_PAGE_SIZE;
    render();
  });

  if (input instanceof HTMLInputElement) {
    const q = getKeyword();
    if (q) {
      input.value = q;
      runSearch();
    }

    input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        runSearch();
      }
    });
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    runSearch();
  });

  setActiveFilterButton();
</script>
