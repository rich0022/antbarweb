---
interface Props {
  title: string;
  href: string;
  image: string;
  dateText?: string;
}

const { title, href, image, dateText = '' } = Astro.props;
---

<section class="archive-featured-wrap" aria-label="Featured post">
  <div class="archive-featured">
    <article class="archive-featured__card scroll-reveal" data-animate="fadeInUp">
    <div class="archive-featured__media">
      <a href={href} aria-label={title}>
        <img loading="lazy" decoding="async" width="1489" height="1003" src={image} alt="" />
      </a>
    </div>
    <div class="archive-featured__copy">
      <h3 class="archive-featured__title">
        <a href={href}>{title}</a>
      </h3>
      {dateText && <p class="archive-featured__date">{dateText}</p>}
      <a class="archive-featured__button" href={href}>View More</a>
    </div>
    </article>
  </div>
</section>
