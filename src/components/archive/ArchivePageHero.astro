---
interface Props {
  desktopImage: string;
  mobileImage: string;
  heading: string;
  tagline: string;
}

const { desktopImage, mobileImage, heading, tagline } = Astro.props;
---

<section class="archive-hero" aria-label={heading}>
  <picture class="archive-hero__media archive-hero__media--desktop">
    <img loading="lazy" decoding="async" width="2560" height="952" src={desktopImage} alt="" />
  </picture>
  <picture class="archive-hero__media archive-hero__media--mobile">
    <img loading="lazy" decoding="async" width="1170" height="1931" src={mobileImage} alt="" />
  </picture>
  <div class="archive-hero__overlay">
    <h2 class="archive-hero__heading scroll-reveal" data-animate="fadeInUp">
      {heading}
    </h2>
    <p class="archive-hero__tagline scroll-reveal" data-animate="fadeInUp">
      {tagline}
    </p>
  </div>
</section>
