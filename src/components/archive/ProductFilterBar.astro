---
interface Props {
  activeTab?: 'all' | 'disposable' | 'pod-sys';
}

const { activeTab = 'all' } = Astro.props;

const TABS = [
  { id: 'all' as const, dataId: 'cfa615c', label: 'All Products' },
  { id: 'disposable' as const, dataId: '3fa0521', label: 'Disposable' },
  { id: 'pod-sys' as const, dataId: 'ee4a308', label: 'Closed Pod system' },
];
---

<div
  class="elementor-element elementor-element-007d602 e-con-full e-flex elementor-invisible e-con e-parent"
  data-id="007d602"
  data-element_type="container"
  data-settings='{"animation":"fadeInUp"}'
>
  <div
    class="elementor-element elementor-element-0c9afac elementor-widget elementor-widget-heading"
    data-id="0c9afac"
    data-element_type="widget"
    data-widget_type="heading.default"
  >
    <h1 class="elementor-heading-title elementor-size-default">ANTBAR PRODUCTS</h1>
  </div>
  <div
    class="elementor-element elementor-element-c25eb3f e-flex e-con-boxed e-con e-child"
    data-id="c25eb3f"
    data-element_type="container"
  >
    <div class="e-con-inner">
      {TABS.map((tab) => {
        const isActive = tab.id === activeTab;
        return (
          <div
            class={`elementor-element elementor-element-${tab.dataId}${isActive ? ' active' : ''} elementor-widget elementor-widget-button`}
            data-id={tab.dataId}
            data-element_type="widget"
            data-widget_type="button.default"
          >
            <a class="elementor-button elementor-size-sm" role="button" data-product-tab={tab.id}>
              <span class="elementor-button-content-wrapper">
                <span class="elementor-button-text">{tab.label}</span>
              </span>
            </a>
          </div>
        );
      })}
    </div>
  </div>
</div>
