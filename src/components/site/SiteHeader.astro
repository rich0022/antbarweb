---
import { HEADER_SEARCH_ICON, HEADER_WARNING_TEXT, PRIMARY_NAV, PRODUCT_MEGA_TILES, SITE_LOGO } from '../../data/site-navigation';
import { isNavItemActive } from '../../lib/nav-active';

const pathname = Astro.url.pathname;
---

<header class="site-header dynamic-header header-full-width" data-site-shell-header>
  <div class="site-header__warning" data-site-shell-warning id="hTop">
    <div class="site-shell-frame">
      <p>{HEADER_WARNING_TEXT}</p>
    </div>
  </div>

  <div class="site-header__bar" data-site-shell-header-bar id="hNav">
    <div class="site-shell-frame site-header__inner">
      <a class="site-header__brand" href={SITE_LOGO.href} aria-label="Antbar home">
        <img
          src={SITE_LOGO.src}
          width={SITE_LOGO.width}
          height={SITE_LOGO.height}
          alt={SITE_LOGO.alt}
          srcset={SITE_LOGO.srcset}
          sizes={SITE_LOGO.sizes}
        />
      </a>

      <nav class="site-header__nav" data-site-shell-nav id="mainNav" aria-label="Primary navigation">
        <ul class="site-header__nav-list">
          {
            PRIMARY_NAV.map((item) => {
              const active = isNavItemActive(item.href, pathname);
              const panelId = `site-shell-nav-panel-${item.menuItemId}`;

              return (
                <li class:list={['site-header__nav-item', item.dropdown && 'site-header__nav-item--has-panel']} data-site-shell-nav-item>
                  <div class="site-header__nav-entry">
                    <a
                      class:list={['site-header__nav-link', active && 'is-current']}
                      href={item.href}
                      aria-current={active ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                    {item.dropdown && (
                      <button
                        class="site-header__nav-toggle"
                        type="button"
                        data-site-shell-nav-toggle
                        aria-label={`Toggle ${item.label} menu`}
                        aria-expanded="false"
                        aria-controls={panelId}
                      >
                        <svg viewBox="0 0 12 8" aria-hidden="true">
                          <path d="M1 1.25 6 6.25 11 1.25" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </button>
                    )}
                  </div>

                  {item.panel === 'products' && (
                    <div class="site-header__nav-panel" id={panelId} data-site-shell-nav-panel>
                      <div class="site-shell-frame site-header__nav-panel-inner site-header__nav-panel-inner--products">
                        {PRODUCT_MEGA_TILES.map((tile) => (
                          <a class="site-header__mega-card" href={tile.href}>
                            <img src={tile.src} width={tile.width} height={tile.height} alt={tile.caption} loading="lazy" />
                            <span>{tile.caption}</span>
                          </a>
                        ))}
                      </div>
                    </div>
                  )}

                  {item.panel === 'links' && item.links && (
                    <div class="site-header__nav-panel" id={panelId} data-site-shell-nav-panel>
                      <div class="site-shell-frame site-header__nav-panel-inner">
                        <ul class="site-header__nav-panel-links">
                          {item.links.map((link) => (
                            <li>
                              <a
                                class:list={['site-header__nav-panel-link', isNavItemActive(link.href, pathname) && 'is-current']}
                                href={link.href}
                              >
                                {link.label}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>
                  )}
                </li>
              );
            })
          }
        </ul>
      </nav>

      <div class="site-header__actions">
        <button
          class="site-header__icon-button site-header__menu-button"
          type="button"
          id="hMenu"
          data-site-shell-trigger="menu"
          aria-haspopup="dialog"
          aria-controls="elementor-popup-modal-2978"
          aria-label="Open menu"
        >
          <span class="site-header__menu-icon" aria-hidden="true">
            <svg class="site-header__menu-icon-open" viewBox="0 0 24 24">
              <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            <svg class="site-header__menu-icon-close" viewBox="0 0 24 24">
              <path d="M6 6l12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
        </button>

        <button
          class="site-header__icon-button site-header__search-button"
          type="button"
          id="hSearchTrigger"
          data-site-shell-trigger="search"
          aria-haspopup="dialog"
          aria-controls="elementor-popup-modal-1132"
          aria-label="Open search"
        >
          <img src={HEADER_SEARCH_ICON.src} width={HEADER_SEARCH_ICON.width} height={HEADER_SEARCH_ICON.height} alt="" />
        </button>
      </div>
    </div>
  </div>
</header>
