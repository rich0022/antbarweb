---

<footer class="site-footer dynamic-footer footer-full-width" data-site-shell-footer>
  <div class="site-footer__primary">
    <div class="site-shell-frame site-footer__inner">
      <a class="site-footer__brand" href={SITE_LOGO.href} aria-label="Antbar home">
        <img
          src={SITE_LOGO.src}
          width={SITE_LOGO.width}
          height={SITE_LOGO.height}
          alt={SITE_LOGO.alt}
          srcset={SITE_LOGO.srcset}
          sizes={SITE_LOGO.sizes}
        />
      </a>

      <div class="site-footer__grid">
        <div class="site-footer__mobile-nav">
          <h3 class="site-footer__section-title">
            <a href="/all-products/">All products</a>
          </h3>
          <details class="site-footer__accordion">
            <summary>About</summary>
            <ul class="site-footer__accordion-links">
              {FOOTER_MOBILE_ACCORDION[0]?.rows.map((row) => <li><a href={row.href}>{row.label}</a></li>)}
            </ul>
          </details>
          <details class="site-footer__accordion">
            <summary>Community</summary>
            <ul class="site-footer__accordion-links">
              {FOOTER_MOBILE_ACCORDION[1]?.rows.map((row) => <li><a href={row.href}>{row.label}</a></li>)}
            </ul>
          </details>
          <details class="site-footer__accordion">
            <summary>Support</summary>
            <ul class="site-footer__accordion-links">
              {FOOTER_MOBILE_ACCORDION[2]?.rows.map((row) => <li><a href={row.href}>{row.label}</a></li>)}
            </ul>
          </details>
        </div>

        {
          FOOTER_DESKTOP_COLUMNS.map((column) => (
            <section class="site-footer__column">
              <h3 class="site-footer__section-title">{column.title}</h3>
              <ul class="site-footer__link-list">
                {column.links.map((link) => (
                  <li>
                    <a href={link.href}>{link.label}</a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }

        <section class="site-footer__column site-footer__column--contact">
          <h3 class="site-footer__section-title">Contact</h3>
          <div class="site-footer__contact-text">
            <p>
              E-mail: <a href={`mailto:${FOOTER_CONTACT.email}`}>{FOOTER_CONTACT.email}</a>
            </p>
            <p>TEL: {FOOTER_CONTACT.phone}</p>
            <p>Add: {FOOTER_CONTACT.address}</p>
          </div>
        </section>

        <section class="site-footer__column site-footer__column--social">
          <h3 class="site-footer__section-title">Follow us</h3>
          <p class="site-footer__social-copy">Have Fun With ANTBAR on social medias:</p>
          <div class="site-footer__social-list" role="list">
            {
              FOOTER_SOCIAL.map((item) => {
                const icon = socialIconPaths[item.iconClass];

                return (
                  <a class="site-footer__social-link" href={item.href} target="_blank" rel="nofollow" aria-label={item.label} role="listitem">
                    <svg aria-hidden="true" viewBox={icon.viewBox} xmlns="http://www.w3.org/2000/svg">
                      <path d={icon.path} />
                    </svg>
                  </a>
                );
              })
            }
          </div>
        </section>
      </div>
    </div>
  </div>

  <div class="site-footer__divider"></div>

  <div class="site-footer__meta">
    <div class="site-shell-frame site-footer__meta-inner">
      <div>{FOOTER_COPYRIGHT}</div>
      <a href={PRIVACY_POLICY_HREF}>Privacy Policy</a>
    </div>
  </div>
</footer>
