---
import { PRODUCT_MEGA_TILES, PRIMARY_NAV } from '../../data/site-navigation';

const homeLink = PRIMARY_NAV.find((item) => item.label === 'Home');
const contactLink = PRIMARY_NAV.find((item) => item.label === 'Contact');
const groupedLinks = PRIMARY_NAV.filter((item) => item.dropdown && item.panel === 'links');
---

<div
  id="elementor-popup-modal-2978"
  class="home-dialog home-dialog--menu"
  data-home-dialog="menu"
  hidden
  aria-hidden="true"
>
  <button class="home-dialog__backdrop" type="button" aria-label="Close menu" data-close-dialog></button>
  <div class="home-dialog__panel home-dialog__panel--menu" role="dialog" aria-modal="true" aria-labelledby="home-mobile-menu-title">
    <div class="home-dialog__header">
      <h2 id="home-mobile-menu-title">Menu</h2>
      <button class="home-dialog__close" type="button" aria-label="Close menu" data-close-dialog>&times;</button>
    </div>
    <nav class="home-mobile-menu" aria-label="Mobile menu">
      {homeLink && (
        <a class="home-mobile-menu__root-link" href={homeLink.href}>
          {homeLink.label}
        </a>
      )}

      <details class="home-mobile-menu__section">
        <summary>Products</summary>
        <div class="home-mobile-menu__products">
          {PRODUCT_MEGA_TILES.map((tile) => (
            <a class="home-mobile-menu__product-card" href={tile.href}>
              <img src={tile.src} width={tile.width} height={tile.height} alt={tile.caption} loading="lazy" />
              <span>{tile.caption}</span>
            </a>
          ))}
          <a class="home-mobile-menu__cta" href="/all-products/">
            Learn more
          </a>
        </div>
      </details>

      {groupedLinks.map((item) => (
        <details class="home-mobile-menu__section">
          <summary>{item.label}</summary>
          <div class="home-mobile-menu__links">
            {item.links?.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        </details>
      ))}

      {contactLink && (
        <a class="home-mobile-menu__root-link" href={contactLink.href}>
          {contactLink.label}
        </a>
      )}
    </nav>
  </div>
</div>

<div
  id="elementor-popup-modal-1132"
  class="home-dialog home-dialog--search"
  data-home-dialog="search"
  hidden
  aria-hidden="true"
>
  <button class="home-dialog__backdrop" type="button" aria-label="Close search" data-close-dialog></button>
  <div class="home-dialog__panel home-dialog__panel--search" role="dialog" aria-modal="true" aria-labelledby="home-search-title">
    <div class="home-dialog__header">
      <h2 id="home-search-title">Search</h2>
      <button class="home-dialog__close" type="button" aria-label="Close search" data-close-dialog>&times;</button>
    </div>
    <form class="home-search-form" data-home-search-form>
      <label class="home-search-form__label" for="home-search-input">Search...</label>
      <div class="home-search-form__row">
        <input id="home-search-input" class="home-search-form__input" type="search" name="q" placeholder="Search..." />
        <button class="home-search-form__submit" type="submit">Search</button>
      </div>
    </form>
  </div>
</div>

<div
  id="elementor-popup-modal-1146"
  class="home-dialog home-dialog--age"
  data-home-dialog="age"
  hidden
  aria-hidden="true"
>
  <div class="home-dialog__backdrop home-dialog__backdrop--locked"></div>
  <div class="home-dialog__panel home-dialog__panel--age" role="dialog" aria-modal="true" aria-labelledby="home-age-title">
    <img
      class="home-age-gate__brand"
      src="/wp-content/uploads/2023/12/15.png"
      width="168"
      height="45"
      alt="Antbar"
    />
    <h2 id="home-age-title">AGE VERIFICATION</h2>
    <p>
      To access antbar website, you must be aged 21 years or over, please verify your age before
      entering the site.
    </p>
    <div class="home-age-gate__actions">
      <a class="home-age-gate__button home-age-gate__button--ghost" href="https://www.google.com/" rel="nofollow">
        I am not 21+
      </a>
      <button class="home-age-gate__button" type="button" data-age-accept>
        Yes, I am 21+
      </button>
    </div>
  </div>
</div>
