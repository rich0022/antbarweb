---
import { PRODUCT_MEGA_TILES, PRIMARY_NAV } from '../../data/site-navigation';

const homeLink = PRIMARY_NAV.find((item) => item.label === 'Home');
const contactLink = PRIMARY_NAV.find((item) => item.label === 'Contact');
const groupedLinks = PRIMARY_NAV.filter((item) => item.dropdown && item.panel === 'links');
const mobileProductTiles = [
  ...PRODUCT_MEGA_TILES,
  {
    href: '/all-products/',
    src: '/wp-content/uploads/2024/03/AT800.png',
    width: 563,
    height: 697,
    caption: 'All',
  },
];
---

<div
  id="site-shell-menu-dialog"
  class="site-shell-dialog site-shell-dialog--menu"
  data-site-shell-dialog="menu"
  hidden
  aria-hidden="true"
>
  <button class="site-shell-dialog__backdrop" type="button" aria-label="Close menu" data-site-shell-close></button>
  <div class="site-shell-dialog__panel site-shell-dialog__panel--menu" role="dialog" aria-modal="true" aria-labelledby="site-shell-menu-title">
    <div class="site-shell-menu-shell">
      <nav class="site-shell-menu" data-site-shell-menu aria-label="Mobile menu">
        <h2 id="site-shell-menu-title" class="site-shell-menu__title">Menu</h2>
        {homeLink && (
          <a class="site-shell-menu__root-link" href={homeLink.href}>
            {homeLink.label}
          </a>
        )}

        <details class="site-shell-menu__section" data-site-shell-menu-section>
          <summary>
            <span>Products</span>
          </summary>
          <div class="site-shell-menu__products">
            {mobileProductTiles.map((tile) => (
              <a class="site-shell-menu__product-card" href={tile.href}>
                <img src={tile.src} width={tile.width} height={tile.height} alt={tile.caption} loading="lazy" />
                <span>{tile.caption}</span>
              </a>
            ))}
          </div>
          <a class="site-shell-menu__cta" href="/all-products/">
            Learn more
          </a>
        </details>

        {groupedLinks.map((item) => (
          <details class="site-shell-menu__section" data-site-shell-menu-section>
            <summary>
              <span>{item.label}</span>
            </summary>
            <div class="site-shell-menu__links">
              {item.links?.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </div>
          </details>
        ))}

        {contactLink && (
          <a class="site-shell-menu__root-link site-shell-menu__root-link--contact" href={contactLink.href}>
            {contactLink.label}
          </a>
        )}
      </nav>
    </div>
  </div>
</div>

<div
  id="site-shell-search-dialog"
  class="site-shell-dialog site-shell-dialog--search"
  data-site-shell-dialog="search"
  hidden
  aria-hidden="true"
>
  <button class="site-shell-dialog__backdrop" type="button" aria-label="Close search" data-site-shell-close></button>
  <div class="site-shell-dialog__panel site-shell-dialog__panel--search" role="dialog" aria-modal="true" aria-labelledby="site-shell-search-title">
    <div class="site-shell-search-shell">
      <button class="site-shell-search-shell__close" type="button" aria-label="Close search" data-site-shell-close>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 6 18 18M18 6 6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
      <h2 id="site-shell-search-title" class="site-shell-search-shell__title">Search</h2>
      <form class="site-shell-search-form" data-site-shell-search-form>
        <div class="site-shell-search-form__row">
          <input id="site-shell-search-input" class="site-shell-search-form__input" type="search" name="q" placeholder="Search..." autocomplete="off" />
          <button class="site-shell-search-form__submit" type="submit" aria-label="Submit search">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2" />
              <path d="m16.5 16.5 4 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </button>
        </div>
      </form>
      <div class="site-shell-search-results" data-site-shell-search-results hidden></div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const dialog = document.getElementById('site-shell-search-dialog');
    const form = dialog?.querySelector('[data-site-shell-search-form]');
    const input = document.getElementById('site-shell-search-input');
    const resultsEl = dialog?.querySelector('[data-site-shell-search-results]');
    if (!dialog || !form || !input || !resultsEl) return;

    let pagefind = null;
    let loadPromise = null;

    const loadPagefind = () => {
      if (loadPromise) return loadPromise;
      loadPromise = import('/pagefind/pagefind.js')
        .then((mod) => { pagefind = mod; })
        .catch(() => {
          resultsEl.innerHTML = '<p class="site-shell-search-results__error">Search is not available.</p>';
          resultsEl.hidden = false;
        });
      return loadPromise;
    };

    const renderResults = (results) => {
      if (!results || results.length === 0) {
        resultsEl.innerHTML = '<p class="site-shell-search-results__empty">No results found.</p>';
        resultsEl.hidden = false;
        return;
      }

      let html = '';
      const limit = Math.min(results.length, 20);
      for (let i = 0; i < limit; i++) {
        const data = results[i].data();
        html += '<article class="site-shell-search-result">';
        html += `<a href="${data.url}">`;
        html += `<h3 class="site-shell-search-result__title">${data.meta?.title || ''}</h3>`;
        if (data.excerpt) {
          html += `<p class="site-shell-search-result__excerpt">${data.excerpt}</p>`;
        }
        html += '</a></article>';
      }
      resultsEl.innerHTML = html;
      resultsEl.hidden = false;
    };

    const doSearch = async (term) => {
      term = term.trim();
      if (!term) { resultsEl.hidden = true; return; }

      await loadPagefind();
      if (!pagefind) return;

      const search = await pagefind.search(term);
      renderResults(search?.results ?? []);
    };

    let debounceTimer = null;
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => doSearch(input.value), 300);
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearTimeout(debounceTimer);
      doSearch(input.value);
    });

    const searchDialogObserver = new MutationObserver(() => {
      if (!dialog.hidden && !dialog.hasAttribute('aria-hidden')) {
        loadPagefind();
        setTimeout(() => input?.focus(), 200);
        if (input.value.trim()) doSearch(input.value);
      }
    });
    searchDialogObserver.observe(dialog, { attributes: true, attributeFilter: ['hidden', 'aria-hidden'] });
  })();
</script>

<div
  id="site-shell-age-dialog"
  class="site-shell-dialog site-shell-dialog--age"
  data-site-shell-dialog="age"
  hidden
  aria-hidden="true"
>
  <div class="site-shell-dialog__backdrop site-shell-dialog__backdrop--locked"></div>
  <div class="site-shell-dialog__panel site-shell-dialog__panel--age" role="dialog" aria-modal="true" aria-labelledby="site-shell-age-title">
    <img
      class="site-shell-age-gate__brand"
      src="/wp-content/uploads/2023/12/15.png"
      width="168"
      height="45"
      alt="Antbar"
    />
    <h2 id="site-shell-age-title">AGE VERIFICATION</h2>
    <p>
      To access antbar website, you must be aged 21 years or over, please verify your age before
      entering the site.
    </p>
    <div class="site-shell-age-gate__actions">
      <a class="site-shell-age-gate__button site-shell-age-gate__button--ghost" href="https://www.google.com/" rel="nofollow">
        I am not 21+
      </a>
      <button class="site-shell-age-gate__button site-shell-age-gate__button--accept" type="button" data-age-accept>
        I am 21+
      </button>
    </div>
  </div>
</div>
