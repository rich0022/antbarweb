---
import { ARTICLE_SOCIAL_LINKS } from '../../data/article-social';
import type { ArticleCard, HotProductCard, TocItem } from '../../lib/article-page';
import ArticlePostList from './ArticlePostList.astro';
import ArticleTocScript from './ArticleTocScript.astro';

interface Props {
  title: string;
  sectionLabel: 'Blog' | 'Review';
  author?: string;
  publishedLabel?: string;
  tocItems?: TocItem[];
  latestItems?: ArticleCard[];
  relatedTitle?: string;
  relatedItems?: ArticleCard[];
  featuredItems?: ArticleCard[];
  hotProducts?: HotProductCard[];
}

const {
  title,
  sectionLabel,
  author = 'Antbar',
  publishedLabel = '',
  tocItems = [],
  latestItems = [],
  relatedTitle = 'Related Articles',
  relatedItems = [],
  featuredItems = [],
  hotProducts = [],
} = Astro.props;

const isReview = sectionLabel === 'Review';
const breadcrumbHref = isReview ? '/review/' : '/blog/';
const breadcrumbSection = isReview ? 'Review' : 'Blog';
const newsletterFormId = isReview ? 'article-newsletter-review' : 'article-newsletter-blog';
---

<main id="content" class="site-main article-page">
  <nav class="article-breadcrumb" aria-label="Breadcrumb">
    <div class="site-shell-frame article-breadcrumb__inner">
      <ol class="article-breadcrumb__list">
        <li class="article-breadcrumb__item">
          <a href="/">Home</a>
        </li>
        <li class="article-breadcrumb__item">
          <a href={breadcrumbHref}>{breadcrumbSection}</a>
        </li>
        <li class="article-breadcrumb__item article-breadcrumb__item--current" aria-current="page">
          <span>{title}</span>
        </li>
      </ol>
    </div>
  </nav>

  <div class="article-layout">
    <div class="site-shell-frame article-layout__inner">
      <article class="article-main">
        <header class="article-header">
          <h1 class="article-header__title">{title}</h1>
          <div class="article-header__meta">
            <p class="article-header__byline">
              by <strong>{author}</strong>
              {publishedLabel && (
                <>
                  {' '}
                  – <time class="article-header__date">{publishedLabel}</time>
                </>
              )}
            </p>
            <ul class="article-header__social" role="list">
              {
                ARTICLE_SOCIAL_LINKS.map((item) => (
                  <li role="listitem">
                    <a
                      class="article-header__social-link"
                      href={item.href}
                      target="_blank"
                      rel="noreferrer"
                      aria-label={item.label}
                    >
                      <Fragment set:html={item.icon} />
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
          <hr class="article-header__rule" />
        </header>

        <div class="article-body">
          <slot />
        </div>
      </article>

      <aside class="article-sidebar" aria-label="Article sidebar">
        <section class="article-sidebar__section article-newsletter" aria-labelledby={`${newsletterFormId}-title`}>
          <h2 id={`${newsletterFormId}-title`} class="article-newsletter__title">
            JOIN OUR NEWS LETTER
          </h2>
          <p class="article-newsletter__text">
            Subscribe to our newsletters to keep updated with the latest Antbar news.
          </p>
          <form class="article-newsletter__form" method="get" action="/contact/" aria-label="Newsletter signup">
            <label class="article-newsletter__label" for={`${newsletterFormId}-email`}>Email</label>
            <div class="article-newsletter__fields">
              <input
                id={`${newsletterFormId}-email`}
                class="article-newsletter__input"
                type="email"
                name="email"
                placeholder="Email Address"
                required
              />
              <button class="article-newsletter__submit" type="submit" aria-label="Submit email">
                <svg aria-hidden="true" viewBox="0 0 256 512" xmlns="http://www.w3.org/2000/svg"><path d="M224.3 273l-136 136c-9.4 9.4-24.6 9.4-33.9 0l-22.6-22.6c-9.4-9.4-9.4-24.6 0-33.9l96.4-96.4-96.4-96.4c-9.4-9.4-9.4-24.6 0-33.9L54.3 103c9.4-9.4 24.6-9.4 33.9 0l136 136c9.5 9.4 9.5 24.6.1 34z"></path></svg>
              </button>
            </div>
          </form>
        </section>

        {
          tocItems.length > 0 && (
            <section class="article-sidebar__section article-toc" aria-labelledby="article-toc-title">
              <h2 id="article-toc-title" class="article-sidebar__heading">Table of Contents</h2>
              <div class="article-sidebar__panel">
              <ol class="article-toc__list">
                {tocItems.map((item) => (
                  <li>
                    <a href={`#${item.id}`}>{item.text}</a>
                  </li>
                ))}
              </ol>
              </div>
            </section>
          )
        }

        {
          latestItems.length > 0 && (
            <section class="article-sidebar__section" aria-labelledby="article-latest-title">
              <h2 id="article-latest-title" class="article-sidebar__heading">Latest Article</h2>
              <div class="article-sidebar__panel">
                <ArticlePostList items={latestItems} variant="text" />
              </div>
            </section>
          )
        }

        {
          relatedItems.length > 0 && (
            <section class="article-sidebar__section" aria-labelledby="article-related-title">
              <h2 id="article-related-title" class="article-sidebar__heading">{relatedTitle}</h2>
              <div class="article-sidebar__panel">
                <ArticlePostList items={relatedItems} variant="text" />
              </div>
            </section>
          )
        }

        {
          featuredItems.length > 0 && (
            <section class="article-sidebar__section" aria-labelledby="article-featured-title">
              <h2 id="article-featured-title" class="article-sidebar__heading">Featured Articles</h2>
              <div class="article-sidebar__panel article-sidebar__panel--featured">
                <ArticlePostList items={featuredItems} variant="featured" />
              </div>
            </section>
          )
        }
      </aside>
    </div>
  </div>

  {
    hotProducts.length > 0 && (
      <section class="article-hot-products" aria-labelledby="article-hot-products-title">
        <div class="site-shell-frame article-hot-products__inner">
          <h2 id="article-hot-products-title" class="article-hot-products__title">HOT SALE PRODUCT</h2>
          <hr class="article-hot-products__divider" />
          <ul class="article-hot-products__grid" role="list">
            {
              hotProducts.map((item) => (
                <li class="article-hot-products__item" role="listitem">
                  <article class="article-hot-card">
                    <a class="article-hot-card__thumb-link" href={item.href} tabindex="-1" aria-hidden="true">
                      <span class="article-hot-card__thumb">
                        <img loading="lazy" decoding="async" src={item.image} alt="" />
                      </span>
                    </a>
                    <h3 class="article-hot-card__title">
                      <a href={item.href}>{item.title}</a>
                    </h3>
                    <a class="article-hot-card__cta" href={item.href} aria-label={`Read more about ${item.title}`}>
                      {item.cta}
                    </a>
                  </article>
                </li>
              ))
            }
          </ul>
          <p class="article-hot-products__more">
            <a class="article-hot-products__more-link hover-grow" href="/all-products/">More products</a>
          </p>
        </div>
      </section>
    )
  }
</main>

<ArticleTocScript tocItems={tocItems} />
