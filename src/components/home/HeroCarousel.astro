---
import { HERO_CAROUSEL_SLIDES } from '../../data/homepage';

const slides = HERO_CAROUSEL_SLIDES;
---

<section class="home-hero" id="indexBn">
  <div
    class="home-hero__widget elementor-widget elementor-widget-n-carousel elementor-pagination-type-bullets elementor-arrows-position-inside elementor-pagination-position-outside"
    data-local-carousel="hero"
    data-carousel-mode="single"
    data-slides-desktop="1"
    data-slides-tablet="1"
    data-slides-mobile="1"
    data-pagination="true"
    data-autoplay-delay="5000"
  >
    <div
      class="home-hero__viewport e-n-carousel swiper swiper-initialized"
      role="region"
      aria-roledescription="carousel"
      aria-label="Hero carousel"
      dir="ltr"
    >
      <div class="home-hero__track swiper-wrapper" aria-live="polite">
        {
          slides.map((slide, index) => (
            <article
              class:list={[
                'home-hero__slide',
                'swiper-slide',
                `home-hero__slide--${slide.id}`,
              ]}
              data-slide={index + 1}
              hidden={index !== 0 ? true : undefined}
              role="group"
              aria-roledescription="slide"
              aria-label={`${index + 1} of ${slides.length}`}
            >
              <div class="home-hero__media">
                <a href={slide.link} class="home-hero__image home-hero__image--desktop">
                  <img
                    loading="eager"
                    decoding="async"
                    width={slide.desktopImage.width}
                    height={slide.desktopImage.height}
                    src={slide.desktopImage.src}
                    alt=""
                    srcset={slide.desktopImage.srcset}
                    sizes={slide.desktopImage.sizes}
                    fetchpriority={index === 0 ? 'high' : 'auto'}
                  />
                </a>
                <a href={slide.link} class="home-hero__image home-hero__image--mobile">
                  <img
                    loading="eager"
                    decoding="async"
                    width={slide.mobileImage.width}
                    height={slide.mobileImage.height}
                    src={slide.mobileImage.src}
                    alt=""
                    srcset={slide.mobileImage.srcset}
                    sizes={slide.mobileImage.sizes}
                  />
                </a>
              </div>
              <div class="home-hero__overlay">
                <div
                  class="home-hero__copy elementor-invisible"
                  data-settings='{"animation":"fadeInUp"}'
                >
                  {
                    slide.titleImage ? (
                      <img
                        class="home-hero__title-image"
                        loading="lazy"
                        decoding="async"
                        width={slide.titleImage.width}
                        height={slide.titleImage.height}
                        src={slide.titleImage.src}
                        alt={slide.titleImage.alt}
                        srcset={slide.titleImage.srcset}
                        sizes={slide.titleImage.sizes}
                      />
                    ) : slide.headingTag ? (
                      <h2 class="home-hero__product-name">
                        <a href={slide.link}>{slide.headingTag}</a>
                      </h2>
                    ) : null
                  }
                  <h2 class="home-hero__tagline">{slide.heading}</h2>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
    <div class="home-hero__arrow home-hero__arrow--prev elementor-swiper-button elementor-swiper-button-prev" role="button" tabindex="0" aria-label="Previous">
      <svg aria-hidden="true" class="e-font-icon-svg e-eicon-chevron-left" viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg"><path d="M646 125C629 125 613 133 604 142L308 442C296 454 292 471 292 487 292 504 296 521 308 533L604 854C617 867 629 875 646 875 663 875 679 871 692 858 704 846 713 829 713 812 713 796 708 779 692 767L438 487 692 225C700 217 708 204 708 187 708 171 704 154 692 142 675 129 663 125 646 125Z"></path></svg>
    </div>
    <div class="home-hero__arrow home-hero__arrow--next elementor-swiper-button elementor-swiper-button-next" role="button" tabindex="0" aria-label="Next">
      <svg aria-hidden="true" class="e-font-icon-svg e-eicon-chevron-right" viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg"><path d="M696 533C708 521 713 504 713 487 713 471 708 454 696 446L400 146C388 133 375 125 354 125 338 125 325 129 313 142 300 154 292 171 292 187 292 204 296 221 308 233L563 492 304 771C292 783 288 800 288 817 288 833 296 850 308 863 321 871 338 875 354 875 371 875 388 867 400 854L696 533Z"></path></svg>
    </div>
    <div class="home-hero__pagination swiper-pagination"></div>
  </div>
</section>
