---
import { PRODUCT_GRID_ITEMS } from '../../data/homepage';

const leftItems = PRODUCT_GRID_ITEMS.filter((item) => item.layout === 'stack-left');
const centerItem = PRODUCT_GRID_ITEMS.find((item) => item.layout === 'feature-center');
const rightItems = PRODUCT_GRID_ITEMS.filter((item) => item.layout === 'stack-right');
---

<section class="home-product-grid" aria-label="Product grid">
  <div class="home-product-grid__layout">
    <div class="home-product-grid__column home-product-grid__column--stack">
      {leftItems.map((item) => (
        <article
          id={`home-product-${item.id}`}
          class="home-product-card scroll-reveal"
          data-animate={item.animation}
        >
          <a class="home-product-card__link" href={item.href} aria-label={item.name}>
            <img
              loading="lazy"
              decoding="async"
              width={item.image.width}
              height={item.image.height}
              src={item.image.src}
              alt=""
              srcset={item.image.srcset}
              sizes={item.image.sizes}
            />
            <h3>{item.name}</h3>
          </a>
        </article>
      ))}
    </div>

    {centerItem && (
      <div class="home-product-grid__column home-product-grid__column--feature">
        <article
          id={`home-product-${centerItem.id}`}
          class="home-product-card home-product-card--feature scroll-reveal"
          data-animate={centerItem.animation}
        >
          <a class="home-product-card__link" href={centerItem.href} aria-label={centerItem.name}>
            <img
              loading="lazy"
              decoding="async"
              width={centerItem.image.width}
              height={centerItem.image.height}
              src={centerItem.image.src}
              alt=""
              srcset={centerItem.image.srcset}
              sizes={centerItem.image.sizes}
            />
            <h3>{centerItem.name}</h3>
          </a>
        </article>
      </div>
    )}

    <div class="home-product-grid__column home-product-grid__column--stack">
      {rightItems.map((item) => (
        <article
          id={`home-product-${item.id}`}
          class="home-product-card scroll-reveal"
          data-animate={item.animation}
        >
          <a class="home-product-card__link" href={item.href} aria-label={item.name}>
            <img
              loading="lazy"
              decoding="async"
              width={item.image.width}
              height={item.image.height}
              src={item.image.src}
              alt=""
              srcset={item.image.srcset}
              sizes={item.image.sizes}
            />
            <h3>{item.name}</h3>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
