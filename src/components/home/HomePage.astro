---
import { PRODUCT_HIGHLIGHT, PRODUCT_INTRO, PRODUCT_VIDEO } from '../../data/homepage';
import BackgroundVideo from '../media/BackgroundVideo.astro';
import HeroCarousel from './HeroCarousel.astro';
import ProductGrid from './ProductGrid.astro';
import GalleryCarousel from './GalleryCarousel.astro';
---

<main id="content" class="site-main home-page">
  <HeroCarousel />

  <section class="home-highlight" id="home-product-highlight" aria-label="Featured product">
    <a class="home-highlight__link" href={PRODUCT_HIGHLIGHT.link} aria-label="View featured product">
      <img
        loading="lazy"
        decoding="async"
        width={PRODUCT_HIGHLIGHT.image.width}
        height={PRODUCT_HIGHLIGHT.image.height}
        src={PRODUCT_HIGHLIGHT.image.src}
        alt=""
        srcset={PRODUCT_HIGHLIGHT.image.srcset}
        sizes={PRODUCT_HIGHLIGHT.image.sizes}
      />
    </a>
  </section>

  <section
    class="home-products-intro scroll-reveal"
    id="home-products"
    aria-labelledby="home-products-title"
    data-animate="fadeInUp"
  >
    <div class="home-products-intro__inner">
      <div class="home-products-intro__copy">
        <h2 id="home-products-title">{PRODUCT_INTRO.heading}</h2>
      </div>
      <div class="home-products-intro__cta">
        <a class="home-products-intro__link" href={PRODUCT_INTRO.buttonHref}>
          {PRODUCT_INTRO.buttonText}
        </a>
      </div>
    </div>
  </section>

  <ProductGrid />

  <section
    class="home-video scroll-reveal"
    id="home-product-video"
    aria-label="Product video"
    data-animate="fadeInUp"
  >
    <div class="home-video__frame">
      <BackgroundVideo class="home-video__media" sources={PRODUCT_VIDEO} />
    </div>
  </section>

  <GalleryCarousel />
</main>
